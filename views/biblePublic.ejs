                    renderDevocionalBiblia(d);
                    var devBibliaActions = document.getElementById('dev-biblia-actions');
                    if (devBibliaActions) devBibliaActions.style.display = 'flex';
                } catch (e) {
                    container.innerHTML = '<p class="bible-error">' + (e.message || 'Erro ao carregar.') + '</p>';
                }
            }

