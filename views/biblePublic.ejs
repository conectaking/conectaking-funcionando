            async function setDevocionalReadStatus(day, read) {
                var btn = document.getElementById('devocional-btn-mark-read');
                if (!btn) return;
                if (read) {
                    btn.innerHTML = '<i class="fas fa-check-circle" style="color:var(--green, #22c55e)"></i> Lido';
                    btn.classList.add('read');
                    btn.disabled = true;
                } else {
                    btn.innerHTML = '<i class="far fa-check-circle"></i> Marcar como lido';
                    btn.classList.remove('read');
                    btn.disabled = false;
                }
            }

            async function loadDevocionalReadStatus(day) {
                if (!day) return;
                try {
                    var vid = getVisitorId();
                    var res = await fetch(API_URL + '/api/bible/devotional/read-status?visitor_id=' + encodeURIComponent(vid) + '&days=' + day);
                    var json = await res.json().catch(function() { return {}; });
                    var read = (json.data && json.data.read) || [];
                    var isRead = read.some(function(r) { return r.day_of_year === day; });
                    setDevocionalReadStatus(day, isRead);
                } catch (e) {}
            }

            async function loadDevocional() {
                var el = document.getElementById('devocional-container');
                var actionsEl = document.getElementById('devocional-actions');
                try {
                    var res = await fetch(API_URL + '/api/bible/devocional-do-dia');
                    var json = await res.json().catch(function() { return {}; });
                    var d = json.data;
                    if (!d) throw new Error('Devocional não encontrado');
                    currentDevocionalDay = (d.day_of_year && d.day_of_year >= 1 && d.day_of_year <= 365) ? d.day_of_year : getDayOfYear();
                    currentDevocionalData = { titulo: d.titulo, versiculo_ref: d.versiculo_ref, versiculo_texto: d.versiculo_texto, reflexao: d.reflexao, aplicacao: d.aplicacao, oracao: d.oracao };
                    var html = '<div class="bible-ref">' + (d.titulo || '') + '</div><div style="color:#FFC700;font-size:0.9rem;margin-bottom:12px">' + (d.versiculo_ref || d.versiculo || '') + '</div>';
                    if (d.versiculo_texto) html += '<div class="bible-text" style="color:#e8e8e8;line-height:1.7;margin-bottom:16px">"' + (d.versiculo_texto || '').replace(/\n/g, '<br>') + '"</div>';
                    html += '<div class="bible-text" style="color:#e8e8e8;line-height:1.7">' + (d.reflexao || d.texto || '').replace(/\n/g, '<br>') + '</div>';
                    if (d.aplicacao) html += '<div class="bible-reflexao" style="margin-top:16px"><strong>Aplicação Prática</strong><br>' + (d.aplicacao || '').replace(/\n/g, '<br>') + '</div>';
                    if (d.oracao) html += '<div class="bible-reflexao" style="margin-top:16px"><strong>Oração</strong><br>' + (d.oracao || '').replace(/\n/g, '<br>') + '</div>';
                    el.innerHTML = html;
                    if (actionsEl) actionsEl.style.display = 'flex';
                    devocionalLoaded = true;
                    loadDevocionalReadStatus(currentDevocionalDay);
                    loadDevocionalStreak();
                    document.getElementById('devocional-btn-share').onclick = shareDevocional;
                    document.getElementById('devocional-btn-mark-read').onclick = markDevocionalRead;
                } catch (e) {
                    el.innerHTML = '<div class="bible-error">' + (e.message || 'Erro ao carregar.') + '</div>';
                }
            }

            async function loadDevocionalStreak() {
                var streakEl = document.getElementById('devocional-streak');
                var numEl = document.getElementById('devocional-streak-num');
                if (!streakEl || !numEl) return;
                try {
                    var today = getDayOfYear();
                    var days = [];
                    for (var i = 0; i < 30; i++) {
                        var d = today - i;
                        if (d < 1) d += 365;
                        days.push(d);
                    }
                    var vid = getVisitorId();
                    var res = await fetch(API_URL + '/api/bible/devotional/read-status?visitor_id=' + encodeURIComponent(vid) + '&days=' + days.join(','));
                    var json = await res.json().catch(function() { return {}; });
                    var read = (json.data && json.data.read) || [];
                    var readSet = {};
                    read.forEach(function(r) { readSet[r.day_of_year] = true; });
                    var streak = 0;
                    for (var j = 0; j < 30; j++) {
                        var day = today - j;
                        if (day < 1) day += 365;
                        if (!readSet[day]) break;
                        streak++;
                    }
                    numEl.textContent = streak;
                    streakEl.style.display = streak > 0 ? 'inline' : 'none';
                } catch (e) { streakEl.style.display = 'none'; }
            }

            function shareDevocional() {
                if (!currentDevocionalData) return;
                var ref = (currentDevocionalData.versiculo_ref || '').trim();
                var txt = (currentDevocionalData.versiculo_texto || '').trim();
                var titulo = (currentDevocionalData.titulo || '').trim();
                var reflexao = (currentDevocionalData.reflexao || '').replace(/<[^>]+>/g, '').slice(0, 200);
                var link = (typeof window !== 'undefined' && window.location && window.location.href) ? window.location.href.split('?')[0] : '';
                var shareText = (titulo ? titulo + '\n\n' : '') + (ref ? ref + (txt ? ' — ' + txt : '') + '\n\n' : '') + (reflexao ? reflexao + '...\n\n' : '') + (link ? 'Link: ' + link : '') + '\n\n— Bíblia King';
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(shareText).then(function() {
                        if (confirm('Devocional copiado! Deseja compartilhar no WhatsApp?')) window.open('https://wa.me/?text=' + encodeURIComponent(shareText));
                    }).catch(function() { window.open('https://wa.me/?text=' + encodeURIComponent(shareText)); });
                } else {
                    window.open('https://wa.me/?text=' + encodeURIComponent(shareText));
                }
            }

            async function markDevocionalRead() {
                if (!currentDevocionalDay) return;
                var btn = document.getElementById('devocional-btn-mark-read');
                if (btn && btn.disabled) return;
                try {
                    var vid = getVisitorId();
                    var res = await fetch(API_URL + '/api/bible/devotional/mark-read', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ day_of_year: currentDevocionalDay, visitor_id: vid })
                    });
                    var json = await res.json().catch(function() { return {}; });
                    if (json.success !== false) {
                        setDevocionalReadStatus(currentDevocionalDay, true);
                        loadDevocionalStreak();
                        loadMeuProgresso();
                    }
                } catch (e) {}
            }

            async function loadPlanoDay(dayNum) {
                var el = document.getElementById('plano-content');
                if (!el) return;
                var d = parseInt(dayNum, 10);
                if (d < 1 || d > 365) { el.innerHTML = '<p class="bible-error">Informe um dia entre 1 e 365.</p>'; return; }
                el.innerHTML = '<div class="bible-loading"><i class="fas fa-spinner fa-spin"></i><p>Carregando...</p></div>';
                try {
                    var res = await fetch(API_URL + '/api/bible/reading-plan/day/' + d);
                    var json = await res.json().catch(function() { return {}; });
                    if (!res.ok || !json.success) throw new Error(json.message || 'Dia não encontrado');
                    var data = json.data;
                    var bookId = data.book_id;
                    var from = parseInt(data.chapter_from, 10) || 1;
                    var to = parseInt(data.chapter_to, 10) || from;
                    var base = '/' + slug + '/bible/' + bookId + '/';
                    var links = [];
                    for (var c = from; c <= to; c++) {
                        links.push('<a href="' + base + c + '" class="bible-ref" style="display:inline-block;margin:4px 12px 4px 0">Cap. ' + c + '</a>');
                    }
                    var html = '<p style="color:#e8e8e8;margin-bottom:12px"><strong>Dia ' + d + '</strong> — Leitura: ' + (data.summary || bookId + ' cap. ' + from + (to > from ? ' a ' + to : '')) + '</p><p style="margin-bottom:12px">' + links.join(' ') + '</p>';
                    if (data.devocional && (data.devocional.titulo || data.devocional.reflexao)) {
                        html += '<div class="bible-card" style="margin-top:16px;padding:14px;border-radius:10px;background:rgba(0,0,0,0.2);border:1px solid rgba(255,255,255,0.08)">';
                        html += '<div class="bible-ref">' + (data.devocional.titulo || 'Devocional') + '</div>';
                        if (data.devocional.versiculo_ref) html += '<div style="color:#FFC700;font-size:0.9rem;margin:8px 0">' + data.devocional.versiculo_ref + '</div>';
                        if (data.devocional.versiculo_texto) html += '<div class="bible-text" style="color:#e8e8e8;line-height:1.6">' + (data.devocional.versiculo_texto || '').replace(/\n/g, '<br>') + '</div>';
                        if (data.devocional.reflexao) html += '<div class="bible-text" style="color:#ccc;line-height:1.6;margin-top:8px">' + (data.devocional.reflexao || '').replace(/\n/g, '<br>') + '</div>';
                        html += '</div>';
                    }
                    el.innerHTML = html;
                    currentPlanoData = data;
                    var planoActions = document.getElementById('plano-actions');
                    if (planoActions) planoActions.style.display = 'flex';
                } catch (e) {
                    el.innerHTML = '<div class="bible-error">' + (e.message || 'Erro ao carregar o dia.') + '</div>';
                }
            }

            var currentDev365Day = 0;
            (function initDev365Year() {
                var yEl = document.getElementById('dev365-year');
                if (yEl && !yEl.value) yEl.value = new Date().getFullYear();
            })();
            (function initDev365TemaModo() {
                var sel = document.getElementById('dev365-tema-modo');
                var wrap = document.getElementById('dev365-tema-custom-wrap');
                function toggle() {
                    if (!wrap || !sel) return;
                    wrap.style.display = sel.value === 'personalizado' ? 'block' : 'none';
                }
                if (sel) {
                    sel.addEventListener('change', toggle);
                    toggle();
                }
            })();
            async function loadDev365ByDay(day) {
                var el = document.getElementById('dev365-content');
                var chkAi = document.getElementById('chk-dev365-ai');
                var yEl = document.getElementById('dev365-year');
                var useAi = chkAi && chkAi.checked;
                var year = yEl && yEl.value ? parseInt(yEl.value, 10) : new Date().getFullYear();
                if (isNaN(year) || year < 2000 || year > 2100) year = new Date().getFullYear();
                el.innerHTML = '<div class="bible-loading"><i class="fas fa-spinner fa-spin"></i><p>' + (useAi ? 'Gerando com IA…' : 'Carregando…') + '</p></div>';
                try {
                    var q = '?year=' + encodeURIComponent(year) + '&ai=' + (useAi ? '1' : '0');
                    var temaModoEl = document.getElementById('dev365-tema-modo');
                    var temaModo = temaModoEl ? temaModoEl.value : 'mes_auto';
                    q += '&tema_modo=' + encodeURIComponent(temaModo);
                    if (temaModo === 'personalizado') {
                        var tc = document.getElementById('dev365-tema-custom');
                        var tcs = tc && tc.value ? String(tc.value).trim() : '';
                        if (tcs) q += '&tema=' + encodeURIComponent(tcs);
                    }
                    var chkCunha = document.getElementById('chk-dev365-estilo-cunha');
                    if (chkCunha && chkCunha.checked) q += '&estilo=cunha';
                    var res = await fetch(API_URL + '/api/bible/devotionals-365/' + day + q);
                    var json = await res.json().catch(function() { return {}; });
                    var d = json.data;
                    if (!d) throw new Error('Devocional não encontrado para este dia.');
                    currentDev365Day = day;
                    currentDev365Data = d;
                    var temaBlock = '';
                    if (d.tema_mes || d.tema_ano || d.tema_modo_aplicado) {
                        temaBlock = '<div style="padding:12px 14px;margin-bottom:16px;background:rgba(26,77,46,0.35);border:1px solid rgba(255,199,0,0.28);border-radius:12px;font-size:0.92rem;line-height:1.55">';
                        if (d.tema_modo_aplicado) {
                            var modos = { mes: 'Automático do mês', ano: 'Automático do ano', mes_e_ano: 'Mês + ano', personalizado: 'Personalizado' };
                            temaBlock += '<div style="color:#A1A1A1;font-size:0.8rem;margin-bottom:8px">Modo de tema: <strong style="color:#E8E8E8">' + (modos[d.tema_modo_aplicado] || d.tema_modo_aplicado) + '</strong></div>';
                        }
                        if (d.tema_mes) temaBlock += '<div style="color:#FFC700;font-weight:600;margin-bottom:6px"><i class="fas fa-calendar-alt" style="margin-right:8px"></i>' + (d.tema_modo_aplicado === 'personalizado' ? 'Tema escolhido' : 'Tema do mês') + '</div><div style="color:#E8E8E8;margin-bottom:12px">' + String(d.tema_mes).replace(/</g, '&lt;') + '</div>';
                        if (d.tema_ano && d.tema_modo_aplicado !== 'personalizado') temaBlock += '<div style="color:#FFC700;font-weight:600;margin-bottom:6px"><i class="fas fa-sun" style="margin-right:8px"></i>Tema do ano' + (d.ano_calendario ? ' (' + d.ano_calendario + ')' : '') + '</div><div style="color:#E8E8E8">' + String(d.tema_ano).replace(/</g, '&lt;') + '</div>';
                        if (d.tema_ano && d.tema_modo_aplicado === 'personalizado') temaBlock += '<div style="color:#FFC700;font-weight:600;margin-bottom:6px"><i class="fas fa-sun" style="margin-right:8px"></i>Tema do ano (referência)</div><div style="color:#A1A1A1;font-size:0.88rem">' + String(d.tema_ano).replace(/</g, '&lt;') + '</div>';
                        temaBlock += '</div>';
                    }
                    var aiBanner = '';
                    if (d.ai_gerado) aiBanner = '<p style="font-size:0.88rem;color:#86efac;margin-bottom:12px;line-height:1.45"><i class="fas fa-robot" style="margin-right:6px"></i>Reflexão gerada com IA' + (d.estilo_devocional === 'cunha' ? ' (tom estilo mensagem de fé)' : '') + ', alinhada às instruções de tema acima. A Palavra de Deus continua sendo a medida final.</p>';
                    else if (d.ai_aviso) aiBanner = '<p style="font-size:0.88rem;color:#fbbf24;margin-bottom:12px;line-height:1.45"><i class="fas fa-exclamation-triangle" style="margin-right:6px"></i>' + String(d.ai_aviso).replace(/</g, '&lt;') + '</p>';
                    var reflexaoHtml = (d.reflexao || '').replace(/\n/g, '<br>');
                    var aplicacaoHtml = d.aplicacao ? '<div class="bible-reflexao" style="margin-top:24px;padding-top:20px;border-top:1px solid rgba(255,255,255,0.1)"><strong style="font-size:1rem;color:#FFC700">Aplicação Prática</strong><p style="margin-top:12px;font-size:1.05rem;line-height:1.8">' + (d.aplicacao || '').replace(/\n/g, '<br>') + '</p></div>' : '';
                    var oracaoHtml = d.oracao ? '<div class="bible-reflexao" style="margin-top:20px;padding:16px;background:rgba(255,199,0,0.08);border-radius:12px;border-left:4px solid #FFC700"><strong style="font-size:0.95rem;color:#FFC700">Oração</strong><p style="margin-top:10px;font-size:1.05rem;line-height:1.8;font-style:italic">' + (d.oracao || '').replace(/\n/g, '<br>') + '</p></div>' : '';
                    var btnHtml = '<div class="bible-actions" style="margin-top:20px;flex-wrap:wrap;gap:10px"><button type="button" class="bible-btn" id="dev365-btn-share" data-day="' + day + '"><i class="fas fa-share-alt"></i> Compartilhar</button><button type="button" class="bible-btn secondary dev365-mark-read" data-day="' + day + '"><i class="far fa-check-circle"></i> Marcar como lido</button></div>';
                    el.innerHTML = temaBlock + aiBanner + '<div class="bible-ref" style="font-size:1.2rem;margin-bottom:12px">' + (d.titulo || '') + '</div><div style="color:#FFC700;font-size:1rem;margin-bottom:16px;font-weight:600">' + (d.versiculo_ref || '') + '</div>' + (d.versiculo_texto ? '<div class="bible-text" style="margin-bottom:24px;font-size:1.1rem;line-height:1.8">"' + d.versiculo_texto + '"</div>' : '') + '<div class="bible-text" style="line-height:1.85;font-size:1.05rem">' + reflexaoHtml + '</div>' + aplicacaoHtml + oracaoHtml + btnHtml;
                    var dev365Actions = document.getElementById('dev365-actions');
                    if (dev365Actions) dev365Actions.style.display = 'flex';
                    var dev365ShareBtn = el.querySelector('#dev365-btn-share');
                    if (dev365ShareBtn) dev365ShareBtn.addEventListener('click', function() {
                        if (!currentDev365Data) return;
                        var x = currentDev365Data;
                        var t = (x.titulo || '') + '\n\n' + (x.versiculo_ref || '') + (x.versiculo_texto ? '\n"' + x.versiculo_texto + '"\n\n' : '') + (x.reflexao || '').replace(/<[^>]+>/g, '') + (x.aplicacao ? '\n\nAplicação: ' + x.aplicacao : '') + (x.oracao ? '\n\nOração: ' + x.oracao : '');
                        shareText(t);
                    });
                    (async function checkAndBind() {
                        var vid = getVisitorId();
                        var r = await fetch(API_URL + '/api/bible/devotional/read-status?visitor_id=' + encodeURIComponent(vid) + '&days=' + day);
                        var j = await r.json().catch(function() { return {}; });
                        var read = (j.data && j.data.read) || [];
                        var isRead = read.some(function(r) { return r.day_of_year === day; });
                        var btn = el.querySelector('.dev365-mark-read');
                        if (btn) {
                            if (isRead) { btn.innerHTML = '<i class="fas fa-check-circle" style="color:#22c55e"></i> Lido'; btn.disabled = true; }
                            btn.onclick = async function() {
                                if (btn.disabled) return;
                                try {
                                    await fetch(API_URL + '/api/bible/devotional/mark-read', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ day_of_year: day, visitor_id: vid }) });
                                    btn.innerHTML = '<i class="fas fa-check-circle" style="color:#22c55e"></i> Lido';
                                    btn.disabled = true;
                                } catch (e) {}
                            };
                        }
                    })();
                } catch (e) {
                    el.innerHTML = '<div class="bible-error">' + (e.message || 'Erro ao carregar.') + '</div>';
                    var dev365Actions = document.getElementById('dev365-actions');
                    if (dev365Actions) dev365Actions.style.display = 'none';
                }
            }
            document.getElementById('btn-dev365-load').addEventListener('click', function() {
                var day = parseInt(document.getElementById('dev365-day').value, 10);
                if (day < 1 || day > 365) { alert('Digite um dia entre 1 e 365.'); return; }
                loadDev365ByDay(day);
            });
            document.getElementById('btn-dev365-today').addEventListener('click', function() {
                var day = getDayOfYear();
                document.getElementById('dev365-day').value = day;
                var yEl = document.getElementById('dev365-year');
                if (yEl) yEl.value = new Date().getFullYear();
                loadDev365ByDay(day);
            });
            document.getElementById('btn-plano-load').addEventListener('click', function() {
                var day = parseInt(document.getElementById('plano-day').value, 10);
                if (day < 1 || day > 365) { alert('Digite um dia entre 1 e 365.'); return; }
                loadPlanoDay(day);
            });
            document.getElementById('btn-plano-today').addEventListener('click', function() {
                var day = getDayOfYear();
                document.getElementById('plano-day').value = day;
                loadPlanoDay(day);
            });
            document.getElementById('plano-btn-share').addEventListener('click', function() {
                if (!currentPlanoData) return;
                var d = currentPlanoData;
                var dev = d.devocional;
                var t = 'Plano de leitura — Dia ' + (document.getElementById('plano-day').value || '') + '\n\n' + (d.summary || '') + (dev && (dev.titulo || dev.reflexao) ? '\n\n' + (dev.titulo || '') + '\n' + (dev.versiculo_ref || '') + '\n' + (dev.versiculo_texto || '') + '\n' + (dev.reflexao || '') : '');
                shareText(t);
            });

            async function loadEstudoLivroList() {
                var listEl = document.getElementById('estudo-livro-list');
                if (!listEl) return;
                try {
                    var res = await fetch(API_URL + '/api/bible/study/books');
                    var json = await res.json().catch(function() { return {}; });
                    var books = (json.data && json.data.books) || [];
                    estudoLivroLoaded = true;
                    if (!books.length) {
                        listEl.innerHTML = '<p style="color:#A1A1A1;font-size:0.9rem">Nenhum livro disponível no momento.</p>';
                        return;
                    }
                    listEl.innerHTML = books.map(function(b) {
                        var hasStudy = b.has_study === true;
                        var name = (b.book_name || b.book_id);
                        var bid = (b.book_id || '').replace(/"/g, '&quot;');
                        var label = name + (hasStudy ? '' : ' <span style="font-size:0.8rem;color:#888;font-weight:normal">(em breve)</span>');
                        var url = '/' + slug + '/biblia/estudos-livro/' + (b.book_id || '');
                        return '<a href="' + url + '" target="_blank" rel="noopener" class="bible-btn secondary" data-book-id="' + bid + '" data-has-study="' + (hasStudy ? '1' : '0') + '" style="display:block;width:100%;text-align:left;margin-bottom:8px;padding:12px;text-decoration:none' + (hasStudy ? '' : ';opacity:0.85') + '"><i class="fas fa-book"></i> ' + label + ' <i class="fas fa-external-link-alt" style="float:right;font-size:0.8rem;opacity:0.7"></i></a>';
                    }).join('');
                    if (window.pendingEstudoLivroBookId) {
                        var bid = window.pendingEstudoLivroBookId;
                        delete window.pendingEstudoLivroBookId;
                        window.open('/' + slug + '/biblia/estudos-livro/' + bid, '_blank');
                    }
                } catch (e) {
                    listEl.innerHTML = '<div class="bible-error">' + (e.message || 'Erro ao carregar.') + '</div>';
                }
            }
            async function loadEstudoLivroDetail(bookId) {
                var listEl = document.getElementById('estudo-livro-list');
                var detailEl = document.getElementById('estudo-livro-detail');
                var bodyEl = document.getElementById('estudo-livro-body');
                if (!detailEl || !bodyEl) return;
                listEl.style.display = 'none';
                detailEl.style.display = 'block';
                bodyEl.innerHTML = '<div class="bible-loading"><i class="fas fa-spinner fa-spin"></i><p>Carregando...</p></div>';
                try {
                    var res = await fetch(API_URL + '/api/bible/study/book/' + encodeURIComponent(bookId));
                    var json = await res.json().catch(function() { return {}; });
                    if (!res.ok || !json.success) throw new Error(json.message || 'Estudo não encontrado');
                    var d = json.data;
                    currentEstudoLivroData = { title: d.title, content: d.content, bookId: bookId };
                    var html = (d.title ? '<h3 style="color:#FFC700;font-size:1.05rem;margin-bottom:12px">' + d.title + '</h3>' : '') +
                        '<div style="color:#e8e8e8;line-height:1.65;white-space:pre-wrap;font-size:0.95rem;margin-bottom:20px">' + (d.content || '').replace(/\n/g, '<br>') + '</div>';
                    if (d.chapters && d.chapters.length) {
                        html += '<p style="color:#A1A1A1;font-size:0.9rem;margin-bottom:8px">Estudos por capítulo:</p><p style="margin:0">';
                        d.chapters.forEach(function(c) {
                            html += '<a href="/' + slug + '/bible/' + bookId + '/' + c.chapter_number + '" class="bible-ref" style="display:inline-block;margin:4px 12px 4px 0">Cap. ' + c.chapter_number + (c.title ? ' — ' + c.title : '') + '</a> ';
                        });
                        html += '</p>';
                    }
                    bodyEl.innerHTML = html;
                    var shareBtn = document.getElementById('estudo-livro-btn-share');
                    if (shareBtn) { shareBtn.style.display = 'inline-flex'; }
                } catch (e) {
                    bodyEl.innerHTML = '<div class="bible-error">' + (e.message || 'Erro ao carregar.') + '</div>';
                }
            }
            document.getElementById('btn-estudo-livro-back').addEventListener('click', function() {
                var listEl = document.getElementById('estudo-livro-list');
                var detailEl = document.getElementById('estudo-livro-detail');
                if (listEl) listEl.style.display = 'block';
                if (detailEl) detailEl.style.display = 'none';
                var shareBtn = document.getElementById('estudo-livro-btn-share');
                if (shareBtn) shareBtn.style.display = 'none';
            });
            document.getElementById('estudo-livro-btn-share').addEventListener('click', function() {
                if (!currentEstudoLivroData) return;
                var t = (currentEstudoLivroData.title || 'Estudo') + '\n\n' + (currentEstudoLivroData.content || '').replace(/<[^>]+>/g, '');
                shareText(t);
            });

            (async function loadEstudosPublic() {
                var el = document.getElementById('estudos-public-content');
                try {
                    var res = await fetch(API_URL + '/api/bible/study-themes');
                    var json = await res.json().catch(function() { return {}; });
                    var themes = (json.data && json.data.themes) || [];
                    if (!themes.length) { el.innerHTML = '<p style="color:#A1A1A1">Nenhum tema disponível.</p>'; return; }
                    el.innerHTML = themes.map(function(t) {
                        return '<div style="margin-bottom:12px;padding:12px;border:1px solid rgba(255,255,255,0.08);border-radius:8px"><strong style="color:#FFC700">' + t.nome + '</strong>' + (t.descricao ? '<p style="font-size:0.85rem;color:#A1A1A1;margin-top:6px">' + t.descricao + '</p>' : '') + '<p style="font-size:0.85rem;color:#7dd3fc;margin-top:8px">Acesse pelo painel do cartão para ver os estudos.</p></div>';
                    }).join('');
                } catch (e) { el.innerHTML = '<div class="bible-error">' + (e.message || 'Erro.') + '</div>'; }
            })();

            (async function loadEsbocosPublic() {
                var el = document.getElementById('esbocos-public-content');
                try {
                    var res = await fetch(API_URL + '/api/bible/outline-categories');
                    var json = await res.json().catch(function() { return {}; });
                    var cats = (json.data && json.data.categories) || [];
                    if (!cats.length) { el.innerHTML = '<p style="color:#A1A1A1">Nenhuma categoria disponível.</p>'; return; }
                    var res2 = await fetch(API_URL + '/api/bible/outlines');
                    var json2 = await res2.json().catch(function() { return {}; });
                    var outlines = (json2.data && json2.data.outlines) || [];
                    var byCat = {};
                    outlines.forEach(function(o) { var c = o.category_name || 'Outros'; if (!byCat[c]) byCat[c] = []; byCat[c].push(o); });
                    el.innerHTML = Object.keys(byCat).map(function(cat) {
                        var list = byCat[cat].map(function(o) { return '<div style="font-size:0.9rem;color:#ECECEC;margin-top:6px">• ' + o.titulo + '</div>'; }).join('');
                        return '<div style="margin-bottom:16px"><strong style="color:#FFC700">' + cat + '</strong>' + list + '</div>';
                    }).join('') + '<p style="font-size:0.85rem;color:#7dd3fc;margin-top:12px">Acesse pelo painel do cartão para ver o conteúdo completo dos esboços.</p>';
                } catch (e) { el.innerHTML = '<div class="bible-error">' + (e.message || 'Erro.') + '</div>'; }
            })();

            document.getElementById('btn-busca-public').addEventListener('click', async function() {
                var q = (document.getElementById('busca-public-input').value || '').trim();
                var el = document.getElementById('busca-public-resultados');
                if (!q || q.length < 2) { el.innerHTML = '<p style="color:#A1A1A1">Digite pelo menos 2 caracteres.</p>'; return; }
                el.innerHTML = '<div class="bible-loading"><i class="fas fa-spinner fa-spin"></i><p>Buscando...</p></div>';
                try {
                    var res = await fetch(API_URL + '/api/bible/search?q=' + encodeURIComponent(q) + '&limit=15');
                    var json = await res.json().catch(function() { return {}; });
                    var data = json.data || {};
                    var dev = (data.devotionals || []).map(function(d) { return '<div style="padding:10px;border:1px solid rgba(255,255,255,0.08);border-radius:8px;margin-bottom:8px"><strong style="color:#FFC700">Devocional Dia ' + d.day_of_year + '</strong> — ' + d.titulo + '<div style="font-size:0.85rem;color:#A1A1A1;margin-top:4px">' + (d.reflexao_preview || '').substring(0, 120) + '...</div></div>'; }).join('');
                    var stud = (data.studies || []).map(function(s) { return '<div style="padding:10px;border:1px solid rgba(255,255,255,0.08);border-radius:8px;margin-bottom:8px"><strong style="color:#FFC700">Estudo</strong> — ' + s.titulo + ' (' + (s.theme_name || '') + ')</div>'; }).join('');
                    var out = (data.outlines || []).map(function(o) { return '<div style="padding:10px;border:1px solid rgba(255,255,255,0.08);border-radius:8px;margin-bottom:8px"><strong style="color:#FFC700">Esboço</strong> — ' + o.titulo + ' (' + (o.category_name || '') + ')</div>'; }).join('');
                    var html = (dev ? '<h4 style="margin-bottom:10px;color:#ECECEC;font-size:1rem">Devocionais</h4>' + dev : '') + (stud ? '<h4 style="margin:16px 0 10px;color:#ECECEC;font-size:1rem">Estudos</h4>' + stud : '') + (out ? '<h4 style="margin:16px 0 10px;color:#ECECEC;font-size:1rem">Esboços</h4>' + out : '');
                    el.innerHTML = html || '<p style="color:#A1A1A1">Nenhum resultado encontrado.</p>';
                } catch (e) { el.innerHTML = '<div class="bible-error">' + (e.message || 'Erro na busca.') + '</div>'; }
            });

            (async function init() {
                loadMeuProgresso();
                try {
                    var verse = await loadVerse('');
                    renderVerse(verse);
                } catch (e) {
                    document.getElementById('bible-loading').style.display = 'none';
                    showError(e.message || 'Erro ao carregar versículo do dia.', 'bible-content');
                }
            })();
        })();
    </script>
</body>
</html>
