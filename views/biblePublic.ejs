<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Versículo do Dia — ConectaKing</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', sans-serif;
            background: #0D0D0F;
            background-image: linear-gradient(180deg, #0D0D0F 0%, #12121a 30%, #1a1a1e 60%, #0f0f12 100%);
            color: #ECECEC;
            min-height: 100vh;
            padding: 20px;
            padding-bottom: env(safe-area-inset-bottom, 20px);
        }
        body.theme-light { background: #f0f0eb; background-image: none; color: #1a1a1a; }
        body.theme-light .bible-header h1, body.theme-light .bible-ref { color: #8b6914; }
        body.theme-light .bible-text { color: #222; }
        body.theme-light .bible-card { background: #fff; border-color: rgba(184,134,11,0.3); box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
        body.theme-light .receba-item { background: rgba(0,0,0,0.06); border-color: rgba(184,134,11,0.2); }
        body.theme-light .receba-item:hover { background: rgba(184,134,11,0.12); }
        body.theme-light .receba-item span { color: #333; }
        body.theme-light .back-link { color: #555; }
        body.theme-light .back-link:hover { color: #8b6914; }
        body.theme-light #continuar-onde-parei { background: rgba(184,134,11,0.12); border-color: rgba(184,134,11,0.3); }
        body.theme-light #continuar-onde-parei a { color: #8b6914; }
        body.theme-light #btn-theme-public { background: rgba(0,0,0,0.06); color: #333; border-color: rgba(184,134,11,0.3); }
        .bible-wrap {
            max-width: 680px;
            margin: 0 auto;
            padding: 28px 12px 32px;
        }
        .bible-header {
            position: relative;
            text-align: center;
            margin-bottom: 28px;
        }
        .bible-header .hero-icon {
            font-size: 2.5rem;
            color: #FFC700;
            margin-bottom: 12px;
            filter: drop-shadow(0 2px 8px rgba(255,199,0,0.3));
        }
        .bible-header i.hero-icon { display: inline-block; }
        .bible-header h1 {
            font-family: 'Lora', serif;
            font-size: 1.5rem;
            font-weight: 600;
            color: #ECECEC;
        }
        .bible-header .date-label {
            font-size: 0.9rem;
            color: #A1A1A1;
            margin-top: 6px;
        }
        .bible-card {
            background: rgba(28, 28, 33, 0.95);
            border: 1px solid rgba(255, 199, 0, 0.25);
            border-radius: 16px;
            padding: 28px 24px;
            margin-bottom: 20px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,199,0,0.05);
        }
        .bible-ref {
            font-family: 'Lora', serif;
            font-size: 1rem;
            color: #FFC700;
            margin-bottom: 16px;
            font-weight: 600;
        }
        .bible-text {
            font-family: 'Lora', serif;
            font-size: 1.2rem;
            line-height: 1.7;
            color: #ECECEC;
            margin-bottom: 20px;
        }
        .bible-reflexao {
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.08);
            font-size: 0.95rem;
            line-height: 1.6;
            color: #B8B8B8;
            font-style: italic;
        }
        .bible-reflexao strong {
            color: #ECECEC;
            font-style: normal;
            font-size: 0.85rem;
            display: block;
            margin-bottom: 8px;
        }
        .bible-actions {
            display: flex;
            flex-direction: row;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 24px;
        }
        .bible-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 14px 24px;
            border-radius: 12px;
            font-size: 0.95rem;
            font-weight: 600;
            text-decoration: none;
            color: #000;
            background: #FFC700;
            border: none;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            font-family: inherit;
        }
        .bible-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 199, 0, 0.35);
        }
        .bible-btn.secondary {
            background: rgba(255,255,255,0.08);
            color: #ECECEC;
            border: 1px solid rgba(255,255,255,0.15);
        }
        .bible-btn.secondary:hover {
            background: rgba(255,255,255,0.12);
        }
        .bible-loading {
            text-align: center;
            padding: 48px 24px;
            color: #A1A1A1;
        }
        .bible-loading i {
            font-size: 2.5rem;
            color: #FFC700;
            margin-bottom: 16px;
            animation: pulse 1.5s ease infinite;
        }
        @keyframes pulse { 50% { opacity: 0.6; } }
        .bible-error {
            text-align: center;
            padding: 48px 24px;
            color: #E74C3C;
        }
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #A1A1A1;
            text-decoration: none;
            font-size: 0.9rem;
            margin-bottom: 24px;
            transition: color 0.2s;
        }
        .back-link:hover { color: #FFC700; }
        .translation-select {
            margin-bottom: 20px;
        }
        .translation-select label {
            font-size: 0.85rem;
            color: #A1A1A1;
            display: block;
            margin-bottom: 6px;
        }
        .translation-select select {
            width: 100%;
            padding: 12px 16px;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.15);
            background: rgba(0,0,0,0.3);
            color: #ECECEC;
            font-size: 0.95rem;
        }
        /* Receba mais de Deus hoje */
        .receba-card {
            background: linear-gradient(135deg, #1a4d2e 0%, #0d2818 100%);
            border-radius: 14px;
            padding: 20px;
            margin-bottom: 24px;
            border: 1px solid rgba(255,199,0,0.2);
        }
        .receba-card h2 {
            color: #fff;
            font-size: 1.2rem;
            margin-bottom: 16px;
            font-weight: 600;
        }
        .receba-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
        }
        @media (max-width: 500px) { .receba-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 340px) { .receba-grid { grid-template-columns: 1fr; } }
        .receba-item {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 10px;
            padding: 14px 16px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            transition: all 0.2s;
        }
        .receba-item:hover {
            background: rgba(255,199,0,0.15);
            border-color: rgba(255,199,0,0.4);
        }
        .receba-item.active {
            background: rgba(255,199,0,0.2);
            border-color: #FFC700;
        }
        .receba-item span { color: #fff; font-size: 0.9rem; font-weight: 500; }
        .receba-item i.fa-arrow-right { color: #FFC700; font-size: 0.85rem; }
        .receba-content { display: none; margin-top: 16px; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.15); }
        .receba-content.show { display: block; }
        .receba-content .bible-ref, .receba-content .bible-text, .receba-content .bible-reflexao { color: #e8e8e8; }
        /* Livros da Bíblia */
        .livros-section { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 24px; }
        @media (max-width: 500px) { .livros-section { grid-template-columns: 1fr; } }
        .livros-col {
            background: rgba(255,255,255,0.04);
            border-radius: 12px;
            padding: 16px;
            border: 1px solid rgba(255,255,255,0.08);
        }
        .livros-col h3 { font-size: 0.95rem; color: #FFC700; margin-bottom: 12px; }
        .livros-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px 12px; }
        .livros-grid a { color: #7dd3fc; text-decoration: none; font-size: 0.85rem; }
        .livros-grid a:hover { color: #FFC700; text-decoration: underline; }
    </style>
</head>
<body>
    <div class="bible-wrap">
        <div style="display:flex;flex-wrap:wrap;gap:10px 18px;align-items:center;margin-bottom:8px">
            <a href="<%= typeof dashboardUrl !== 'undefined' && dashboardUrl ? dashboardUrl : ((typeof API_URL !== 'undefined' && API_URL ? API_URL.replace(/\/$/, '') : (typeof baseUrl !== 'undefined' ? baseUrl : '')) + '/dashboard.html') %>" class="back-link" style="margin-bottom:0">
                <i class="fas fa-arrow-left"></i> Voltar ao menu inicial
            </a>
            <% if (typeof profilePublicUrl !== 'undefined' && profilePublicUrl) { %>
            <a href="<%= profilePublicUrl %>" class="back-link" style="margin-bottom:0;font-size:0.85rem;opacity:0.88">Ver perfil público</a>
            <% } %>
        </div>

        <div class="bible-header">
            <i class="fas fa-bible hero-icon"></i>
            <h1>Bíblia</h1>
            <div class="date-label" id="date-label"></div>
            <button type="button" id="btn-theme-public" title="Alternar tema claro/escuro" style="position:absolute;top:20px;right:20px;padding:8px 12px;border-radius:8px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,199,0,0.3);color:#ECECEC;cursor:pointer"><i class="fas fa-moon" id="icon-theme-public"></i></button>
        </div>

        <div id="continuar-onde-parei" style="display:none;margin-bottom:16px;padding:12px 16px;background:rgba(255,199,0,0.1);border:1px solid rgba(255,199,0,0.25);border-radius:10px;">
            <a href="#" id="link-continuar" style="color:#FFC700;text-decoration:none;font-weight:600;display:inline-flex;align-items:center;gap:8px"><i class="fas fa-book-open"></i> Continuar de onde parei: <span id="continuar-label"></span></a>
        </div>

        <!-- Meu progresso (devocionais lidos) -->
        <div class="bible-card" id="card-meu-progresso" style="margin-bottom:24px">
            <h3 style="margin-bottom:12px;color:#FFC700"><i class="fas fa-chart-line" style="margin-right:8px"></i>Meu progresso</h3>
            <p style="font-size:0.9rem;color:#A1A1A1;margin-bottom:12px">Devocionais que você já marcou como lido aparecem aqui.</p>
            <div id="meu-progresso-body">
                <div class="bible-loading" id="meu-progresso-loading"><i class="fas fa-spinner fa-spin"></i><p>Carregando...</p></div>
                <div id="meu-progresso-content" style="display:none">
                    <p style="color:#ECECEC;font-size:1rem;margin-bottom:8px"><strong id="meu-progresso-total">0</strong> devocional(is) lido(s)</p>
                    <p id="meu-progresso-dias" style="font-size:0.85rem;color:#A1A1A1;line-height:1.5"></p>
                </div>
                <div id="meu-progresso-empty" style="display:none;color:#A1A1A1;font-size:0.9rem">Nenhum devocional marcado como lido ainda. Leia o <strong>Devocional Diário</strong> e clique em &quot;Marcar como lido&quot;.</div>
            </div>
        </div>

        <!-- Receba mais de Deus hoje -->
        <div class="receba-card">
            <h2>Receba mais de Deus hoje:</h2>
            <div class="receba-grid">
                <div class="receba-item active" data-tipo="versiculo">
                    <span><i class="fas fa-book-open" style="margin-right:8px"></i>Versículo do Dia</span>
                    <i class="fas fa-arrow-right"></i>
                </div>
                <div class="receba-item" data-tipo="palavra">
                    <span><i class="fas fa-font" style="margin-right:8px"></i>Palavra do Dia</span>
                    <i class="fas fa-arrow-right"></i>
                </div>
                <div class="receba-item" data-tipo="salmo">
                    <span><i class="fas fa-music" style="margin-right:8px"></i>Salmo do Dia</span>
                    <i class="fas fa-arrow-right"></i>
                </div>
                <div class="receba-item" data-tipo="devocional">
                    <span><i class="fas fa-heart" style="margin-right:8px"></i>Devocional Diário</span>
                    <i class="fas fa-arrow-right"></i>
                </div>
                <div class="receba-item" data-tipo="devocional-biblia-inteira">
                    <span><i class="fas fa-bible" style="margin-right:8px"></i>Devocional da Bíblia inteira</span>
                    <i class="fas fa-arrow-right"></i>
                </div>
                <div class="receba-item" data-tipo="plano">
                    <span><i class="fas fa-calendar-check" style="margin-right:8px"></i>Plano de leitura (1 ano)</span>
                    <i class="fas fa-arrow-right"></i>
                </div>
                <div class="receba-item" data-tipo="estudo-livro">
                    <span><i class="fas fa-book-open" style="margin-right:8px"></i>Estudo por livro</span>
                    <i class="fas fa-arrow-right"></i>
                </div>
                <div class="receba-item" data-tipo="cunha">
                    <span><i class="fas fa-microphone" style="margin-right:8px"></i>Devocional Cunha</span>
                    <i class="fas fa-arrow-right"></i>
                </div>
                <div class="receba-item" data-tipo="bible-ia">
                    <span><i class="fas fa-robot" style="margin-right:8px"></i>Assistente IA</span>
                    <i class="fas fa-arrow-right"></i>
                </div>
            </div>
            <div id="receba-versiculo" class="receba-content show">
                <div id="bible-content">
                    <div class="bible-loading" id="bible-loading">
                        <i class="fas fa-spinner fa-spin"></i>
                        <p>Carregando versículo...</p>
                    </div>
                </div>
                <div class="bible-actions" id="bible-actions" style="display: none;">
                    <label for="sel-voice-public" style="font-size:0.85rem;color:#A1A1A1;display:inline-flex;align-items:center;gap:6px">Voz: <select id="sel-voice-public" style="padding:6px 10px;font-size:0.85rem;max-width:180px;color:#ECECEC;background:rgba(255,255,255,0.08);border-radius:8px;border:1px solid rgba(255,199,0,0.3);cursor:pointer"><option value="">Padrão</option></select></label>
                    <button type="button" class="bible-btn" id="btn-ouvir">
                        <i class="fas fa-volume-up"></i> Ouvir
                    </button>
                    <button type="button" class="bible-btn" id="btn-compartilhar">
                        <i class="fas fa-share-alt"></i> Compartilhar
                    </button>
                    <button type="button" class="bible-btn secondary" id="btn-prev-days">
                        <i class="fas fa-history"></i> Ver dias anteriores
                    </button>
                </div>
            </div>
            <div id="receba-palavra" class="receba-content">
                <div id="palavra-container"><div class="bible-loading"><i class="fas fa-spinner fa-spin"></i><p>Carregando...</p></div></div>
                <div class="bible-actions" id="palavra-actions" style="display:none;margin-top:16px">
                    <button type="button" class="bible-btn" id="palavra-btn-ouvir" title="Ouvir"><i class="fas fa-volume-up"></i> Ouvir</button>
                    <button type="button" class="bible-btn" id="palavra-btn-share"><i class="fas fa-share-alt"></i> Compartilhar</button>
                </div>
            </div>
            <div id="receba-salmo" class="receba-content">
                <div id="salmo-container"><div class="bible-loading"><i class="fas fa-spinner fa-spin"></i><p>Carregando...</p></div></div>
                <div class="bible-actions" id="salmo-actions" style="display:none;margin-top:16px">
                    <button type="button" class="bible-btn" id="salmo-btn-ouvir" title="Ouvir"><i class="fas fa-volume-up"></i> Ouvir</button>
                    <button type="button" class="bible-btn" id="salmo-btn-share"><i class="fas fa-share-alt"></i> Compartilhar</button>
                </div>
            </div>
            <div id="receba-devocional" class="receba-content">
                <div id="devocional-container"><div class="bible-loading"><i class="fas fa-spinner fa-spin"></i><p>Carregando...</p></div></div>
                <div id="devocional-actions" class="bible-actions" style="display:none;margin-top:20px;flex-wrap:wrap;gap:10px;align-items:center">
                    <button type="button" class="bible-btn" id="devocional-btn-ouvir" title="Ouvir o devocional do dia"><i class="fas fa-volume-up"></i> Ouvir</button>
                    <button type="button" class="bible-btn secondary" id="devocional-btn-parar" style="display:none;background:rgba(239,68,68,0.2);color:#f87171;border-color:rgba(239,68,68,0.5)"><i class="fas fa-stop"></i> Parar</button>
                    <button type="button" class="bible-btn" id="devocional-btn-share"><i class="fas fa-share-alt"></i> Compartilhar</button>
                    <button type="button" class="bible-btn secondary" id="devocional-btn-mark-read" title="Marcar como lido"><i class="far fa-check-circle"></i> Marcar como lido</button>
                    <span id="devocional-streak" style="display:none;font-size:0.85rem;color:#A1A1A1;"><i class="fas fa-fire" style="color:#FF6B35;margin-right:4px"></i><span id="devocional-streak-num">0</span> dias seguidos</span>
                </div>
            </div>
            <div id="receba-devocional-biblia-inteira" class="receba-content">
                <p style="font-size:0.95rem;color:#A1A1A1;margin-bottom:12px">Percorra a Bíblia inteira em devocionais: um capítulo por dia. Ao terminar, recomeça — para toda a vida.</p>
                <div id="dev-biblia-mode-choice" style="margin-bottom:16px;display:flex;flex-wrap:wrap;gap:10px;align-items:center">
                    <button type="button" class="bible-btn" id="btn-dev-biblia-comecar-hoje" title="Seu dia 1 será hoje; o plano segue até o fim da Bíblia e depois recomeça"><i class="fas fa-play"></i> Começar hoje</button>
                    <span style="color:#A1A1A1;font-size:0.9rem">ou</span>
                    <button type="button" class="bible-btn secondary" id="btn-dev-biblia-calendario" title="Usar mês e dia do calendário (ex.: janeiro = Gênesis)"><i class="fas fa-calendar-alt"></i> Seguir pelo calendário</button>
                </div>
                <div id="dev-biblia-calendario-picker" style="display:none;margin-bottom:16px;flex-wrap:wrap;gap:10px;align-items:center;display:flex">
                    <label style="font-size:0.9rem;color:#A1A1A1">Mês:</label>
                    <select id="dev-biblia-mes" style="padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.2);background:rgba(0,0,0,0.3);color:#ECECEC;font-size:0.9rem;cursor:pointer">
                        <option value="1">Janeiro — Gênesis</option><option value="2">Fevereiro — Êxodo</option><option value="3">Março — Levítico</option><option value="4">Abril — Números</option><option value="5">Maio — Deuteronômio</option><option value="6">Junho — Josué</option><option value="7">Julho — Juízes</option><option value="8">Agosto — Rute</option><option value="9">Setembro — 1 Samuel</option><option value="10">Outubro — 2 Samuel</option><option value="11">Novembro — 1 Reis</option><option value="12">Dezembro — 2 Reis</option>
                    </select>
                    <label style="font-size:0.9rem;color:#A1A1A1">Dia:</label>
                    <input type="number" id="dev-biblia-dia" min="1" max="31" placeholder="1-31" style="width:70px;padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.2);background:rgba(0,0,0,0.3);color:#ECECEC">
                    <button type="button" class="bible-btn" id="btn-dev-biblia-load"><i class="fas fa-book-open"></i> Carregar</button>
                    <button type="button" class="bible-btn secondary" id="btn-dev-biblia-back-calendario" style="display:inline-flex"><i class="fas fa-arrow-left"></i> Voltar</button>
                </div>
                <div id="dev-biblia-sequence-info" style="display:none;margin-bottom:12px;font-size:0.9rem;color:#FFC700"></div>
                <p id="dev-biblia-link-calendario" style="display:none;margin-top:8px"><button type="button" class="bible-btn secondary" id="btn-dev-biblia-usar-calendario" style="font-size:0.85rem"><i class="fas fa-calendar-alt"></i> Usar calendário em vez do meu plano</button></p>
                <div id="devocional-biblia-inteira-container"><p style="color:#A1A1A1;font-size:0.9rem">Clique em <strong>Começar hoje</strong> para o seu dia 1 ser hoje, ou em <strong>Seguir pelo calendário</strong> para usar mês e dia.</p></div>
                <div class="bible-actions" id="dev-biblia-actions" style="display:none;margin-top:16px">
                    <button type="button" class="bible-btn" id="dev-biblia-btn-ouvir" title="Ouvir o devocional"><i class="fas fa-volume-up"></i> Ouvir</button>
                    <button type="button" class="bible-btn secondary" id="dev-biblia-btn-parar" style="display:none;background:rgba(239,68,68,0.2);color:#f87171"><i class="fas fa-stop"></i> Parar</button>
                    <button type="button" class="bible-btn" id="dev-biblia-btn-share"><i class="fas fa-share-alt"></i> Compartilhar</button>
                </div>
            </div>
            <div id="receba-plano" class="receba-content">
                <p style="font-size:0.95rem;color:#A1A1A1;margin-bottom:16px">Leia a Bíblia inteira em um ano: 2–3 capítulos por dia. Escolha o dia (1–365) ou use o dia de hoje.</p>
                <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:20px">
                    <input type="number" id="plano-day" min="1" max="365" placeholder="Dia (1-365)" style="width:100px;padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.15);background:rgba(0,0,0,0.3);color:#ECECEC">
                    <button type="button" class="bible-btn" id="btn-plano-load"><i class="fas fa-book-open"></i> Carregar dia</button>
                    <button type="button" class="bible-btn secondary" id="btn-plano-today"><i class="fas fa-calendar-day"></i> Dia de hoje</button>
                </div>
                <div id="plano-content"><p style="color:#A1A1A1;font-size:0.9rem">Selecione um dia ou clique em "Dia de hoje".</p></div>
                <div class="bible-actions" id="plano-actions" style="display:none;margin-top:16px">
                    <button type="button" class="bible-btn" id="plano-btn-ouvir" title="Ouvir"><i class="fas fa-volume-up"></i> Ouvir</button>
                    <button type="button" class="bible-btn" id="plano-btn-share"><i class="fas fa-share-alt"></i> Compartilhar</button>
                </div>
            </div>
            <div id="receba-estudo-livro" class="receba-content">
                <p style="font-size:0.95rem;color:#A1A1A1;margin-bottom:16px">Introduções e estudos por livro e capítulo da Bíblia.</p>
                <div id="estudo-livro-list"><div class="bible-loading"><i class="fas fa-spinner fa-spin"></i><p>Carregando...</p></div></div>
                <div id="estudo-livro-detail" style="display:none;margin-top:20px;padding:16px;background:rgba(0,0,0,0.2);border:1px solid rgba(255,255,255,0.08);border-radius:12px;">
                    <div style="display:flex;flex-wrap:wrap;gap:10px;align-items:center;margin-bottom:12px">
                        <button type="button" class="bible-btn secondary" id="btn-estudo-livro-back"><i class="fas fa-arrow-left"></i> Voltar</button>
                        <button type="button" class="bible-btn" id="estudo-livro-btn-share" style="display:none"><i class="fas fa-share-alt"></i> Compartilhar</button>
                    </div>
                    <div id="estudo-livro-body"></div>
                </div>
            </div>
            <div id="receba-cunha" class="receba-content">
                <div id="receba-cunha-body">
                    <% if (typeof cunhaDevotionalUrl !== 'undefined' && cunhaDevotionalUrl) { %>
                    <p style="font-size:0.95rem;color:#A1A1A1;margin-bottom:14px;line-height:1.55">Devocional no estilo <strong style="color:#ECECEC">Pr. Cunha</strong> — mensagem e aplicação para o dia.</p>
                    <a href="<%= cunhaDevotionalUrl %>" target="_blank" rel="noopener" class="bible-btn" style="margin-bottom:14px;display:inline-flex"><i class="fas fa-external-link-alt"></i> Abrir Devocional Cunha</a>
                    <% var _cu = String(cunhaDevotionalUrl); var _emb = _cu.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]+)/); if (_emb) { %>
                    <div style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:12px;border:1px solid rgba(255,199,0,0.25);max-width:100%">
                        <iframe title="Devocional Cunha" src="https://www.youtube.com/embed/<%= _emb[1] %>" style="position:absolute;top:0;left:0;width:100%;height:100%;border:0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                    </div>
                    <% } %>
                    <% } else { %>
                    <p style="color:#ECECEC;line-height:1.65;margin-bottom:10px">O administrador pode definir o link oficial do <strong>Devocional Cunha</strong> na variável de ambiente <code style="font-size:0.85rem;color:#FFC700">BIBLE_CUNHA_URL</code> (Render). Ex.: URL de playlist ou vídeo no YouTube.</p>
                    <p style="color:#A1A1A1;font-size:0.9rem">Enquanto isso, você pode buscar &quot;devocional Pr. Cunha&quot; no YouTube.</p>
                    <% } %>
                </div>
            </div>
            <div id="receba-bible-ia" class="receba-content">
                <div id="receba-bible-ia-body">
                    <% if (typeof bibleAiAssistantUrl !== 'undefined' && bibleAiAssistantUrl) { %>
                    <p style="font-size:0.95rem;color:#A1A1A1;margin-bottom:14px;line-height:1.55">Assistente para tirar dúvidas sobre passagens, contexto e aplicação — abre no serviço configurado pelo Conecta King.</p>
                    <a href="<%= bibleAiAssistantUrl %>" target="_blank" rel="noopener" class="bible-btn" style="display:inline-flex"><i class="fas fa-robot"></i> Abrir assistente de IA</a>
                    <% } else { %>
                    <p style="color:#ECECEC;line-height:1.65;margin-bottom:10px">Para ativar o <strong>Assistente IA</strong> da Bíblia, defina <code style="font-size:0.85rem;color:#FFC700">BIBLE_AI_URL</code> no servidor (Render) — por exemplo um chat embutido, página do assistente ou link seguro.</p>
                    <p style="color:#A1A1A1;font-size:0.9rem">Use com discernimento; a Palavra de Deus é a autoridade final.</p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Devocionais 365, Estudos, Esboços -->
        <div class="bible-card">
            <h3 style="margin-bottom:16px;color:#FFC700">Devocionais 365</h3>
            <p style="font-size:0.9rem;color:#A1A1A1;margin-bottom:12px">O catálogo local tem poucos modelos — <strong style="color:#E8E8E8">sem IA</strong> o texto repete ao longo do ano. Use <strong style="color:#E8E8E8">Gerar com IA</strong> para reflexão única alinhada ao tema (exige <code style="color:#FFC700;font-size:0.85rem">OPENAI_API_KEY</code> no Render). Temas automáticos por mês/ano podem ser editados no ficheiro <code style="color:#FFC700;font-size:0.85rem">modules/bible/bible.service.js</code> (listas <code style="color:#FFC700;font-size:0.85rem">TEMAS_MES_PT</code> e <code style="color:#FFC700;font-size:0.85rem">TEMAS_ANO_ROTATIVOS</code>).</p>
            <div style="margin-bottom:12px">
                <label style="font-size:0.85rem;color:#A1A1A1;display:block;margin-bottom:6px">Como aplicar o tema</label>
                <select id="dev365-tema-modo" style="width:100%;max-width:420px;padding:10px 12px;border-radius:8px;border:1px solid rgba(255,255,255,0.15);background:rgba(0,0,0,0.35);color:#ECECEC;font-size:0.9rem;cursor:pointer">
                    <option value="mes_auto">Tema automático do mês (muda conforme o calendário)</option>
                    <option value="ano_auto">Tema automático do ano (prioridade no texto)</option>
                    <option value="mes_e_ano">Mês + ano juntos na reflexão</option>
                    <option value="personalizado">Tema personalizado (escrevo abaixo)</option>
                </select>
            </div>
            <div id="dev365-tema-custom-wrap" style="display:none;margin-bottom:12px">
                <label style="font-size:0.85rem;color:#A1A1A1;display:block;margin-bottom:6px">Seu tema (ex.: perseverança na família)</label>
                <input type="text" id="dev365-tema-custom" maxlength="500" placeholder="Digite o tema que a IA deve seguir" style="width:100%;max-width:420px;padding:10px 12px;border-radius:8px;border:1px solid rgba(255,199,0,0.35);background:rgba(0,0,0,0.3);color:#ECECEC;font-size:0.95rem">
            </div>
            <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px;align-items:center">
                <label style="font-size:0.85rem;color:#A1A1A1">Ano (calendário): <input type="number" id="dev365-year" min="2000" max="2100" style="width:88px;padding:8px 10px;border-radius:8px;border:1px solid rgba(255,255,255,0.15);background:rgba(0,0,0,0.3);color:#ECECEC"></label>
                <label style="font-size:0.85rem;color:#A1A1A1;display:inline-flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" id="chk-dev365-ai" checked style="width:18px;height:18px;accent-color:#FFC700"> Gerar reflexão com IA (recomendado)</label>
            </div>
            <div style="margin-bottom:12px">
                <label style="font-size:0.85rem;color:#A1A1A1;display:inline-flex;align-items:center;gap:8px;cursor:pointer"><input type="checkbox" id="chk-dev365-estilo-cunha" style="width:18px;height:18px;accent-color:#FFC700"> Tom estilo mensagem de rádio / devocional em áudio (inspirado em fé diária; não copia terceiros)</label>
            </div>
            <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px;align-items:center">
                <input type="number" id="dev365-day" min="1" max="365" placeholder="Dia (1-365)" style="width:100px;padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.15);background:rgba(0,0,0,0.3);color:#ECECEC">
                <button type="button" class="bible-btn" id="btn-dev365-load"><i class="fas fa-book-open"></i> Carregar</button>
                <button type="button" class="bible-btn secondary" id="btn-dev365-today"><i class="fas fa-calendar-check"></i> Dia de hoje</button>
            </div>
            <div id="dev365-content"><p style="color:#A1A1A1;font-size:0.9rem">Selecione um dia ou clique em "Dia de hoje".</p></div>
            <div class="bible-actions" id="dev365-actions" style="display:none;margin-top:12px;flex-wrap:wrap;gap:10px">
                <button type="button" class="bible-btn" id="dev365-btn-ouvir" title="Ouvir o devocional 365"><i class="fas fa-volume-up"></i> Ouvir</button>
                <button type="button" class="bible-btn secondary" id="dev365-btn-parar" style="display:none;background:rgba(239,68,68,0.2);color:#f87171"><i class="fas fa-stop"></i> Parar</button>
            </div>
        </div>

        <div class="bible-card">
            <h3 style="margin-bottom:16px;color:#FFC700">Estudos Bíblicos</h3>
            <p style="font-size:0.9rem;color:#A1A1A1;margin-bottom:12px">Estudos por temas: Escatologia, Família, Finanças, Liderança, Hermenêutica.</p>
            <div id="estudos-public-content"><div class="bible-loading"><i class="fas fa-spinner fa-spin"></i><p>Carregando temas...</p></div></div>
        </div>

        <div class="bible-card">
            <h3 style="margin-bottom:16px;color:#FFC700">Esboços para Pregação</h3>
            <p style="font-size:0.9rem;color:#A1A1A1;margin-bottom:12px">Esboços por categorias: Avivamento, Casamento, Prosperidade, Batalha Espiritual, Família.</p>
            <div id="esbocos-public-content"><div class="bible-loading"><i class="fas fa-spinner fa-spin"></i><p>Carregando categorias...</p></div></div>
        </div>

        <div class="bible-card">
            <h3 style="margin-bottom:16px;color:#FFC700">Busca</h3>
            <div style="display:flex;gap:10px;margin-bottom:12px;flex-wrap:wrap">
                <input type="text" id="busca-public-input" placeholder="Buscar em devocionais, estudos e esboços..." style="flex:1;min-width:180px;padding:10px 14px;border-radius:8px;border:1px solid rgba(255,255,255,0.15);background:rgba(0,0,0,0.3);color:#ECECEC">
                <button type="button" class="bible-btn" id="btn-busca-public"><i class="fas fa-search"></i> Buscar</button>
            </div>
            <div id="busca-public-resultados"></div>
        </div>

        <!-- Favoritos (localStorage) -->
        <div class="bible-card" id="card-favoritos" style="display:none">
            <h3 style="margin-bottom:16px;color:#FFC700"><i class="fas fa-star" style="margin-right:8px"></i>Favoritos</h3>
            <p style="font-size:0.9rem;color:#A1A1A1;margin-bottom:12px">Capítulos que você marcou como favoritos.</p>
            <div id="favoritos-list"></div>
        </div>

        <!-- Livros da Bíblia (todos internos - sem links externos) -->
        <div class="bible-card">
            <h3 style="margin-bottom:16px;color:#FFC700">Livros da Bíblia</h3>
            <p style="font-size:0.9rem;color:#A1A1A1;margin-bottom:12px">Leia a Bíblia completa. Clique em um livro para abrir o capítulo 1.</p>
            <div class="livros-section">
                <div class="livros-col">
                    <h3>Antigo Testamento</h3>
                    <div class="livros-grid" id="livros-at">
                        <% (booksManifest && booksManifest.at || []).forEach(function(b) { %>
                        <a href="/<%= slug %>/bible/<%= b.id %>/1"><%= b.name %></a>
                        <% }); %>
                    </div>
                </div>
                <div class="livros-col">
                    <h3>Novo Testamento</h3>
                    <div class="livros-grid" id="livros-nt">
                        <% (booksManifest && booksManifest.nt || []).forEach(function(b) { %>
                        <a href="/<%= slug %>/bible/<%= b.id %>/1"><%= b.name %></a>
                        <% }); %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="<%= typeof ttsScriptSrc !== 'undefined' && ttsScriptSrc ? ttsScriptSrc : 'https://www.conectaking.com.br/js/tts.js' %>"></script>
    <script>
        (function() {
            const API_URL = (typeof window !== 'undefined' && window.location && window.location.origin) ? window.location.origin : '<%= typeof API_URL !== "undefined" ? API_URL : "" %>';
            const translation = '<%= translation || "nvi" %>';
            const slug = '<%= slug %>';
            const initialEstudoBookId = <%= typeof initialEstudoBookId !== 'undefined' && initialEstudoBookId ? JSON.stringify(initialEstudoBookId) : 'null' %>;
            let palavraLoaded = false, salmoLoaded = false, devocionalLoaded = false, devocionalBibliaInteiraLoaded = false, estudoLivroLoaded = false;
            let currentPalavraData = null, currentSalmoData = null, currentDevBibliaData = null, currentPlanoData = null, currentDev365Data = null, currentEstudoLivroData = null;

            function shareText(txt) {
                txt = (txt || '').trim() + '\n\n— Bíblia King';
                var url = 'https://wa.me/?text=' + encodeURIComponent(txt);
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(txt).then(function() {
                        if (confirm('Copiado! Deseja compartilhar no WhatsApp?')) window.open(url);
                    }).catch(function() { window.open(url); });
                } else { window.open(url); }
            }

            async function loadMeuProgresso() {
                var loading = document.getElementById('meu-progresso-loading');
                var content = document.getElementById('meu-progresso-content');
                var empty = document.getElementById('meu-progresso-empty');
                if (!loading || !content || !empty) return;
                try {
                    var vid = getVisitorId();
                    var res = await fetch(API_URL + '/api/bible/devotional/read-status?visitor_id=' + encodeURIComponent(vid));
                    var json = await res.json().catch(function() { return {}; });
                    var read = (json.data && json.data.read) || [];
                    loading.style.display = 'none';
                    if (read.length === 0) {
                        content.style.display = 'none';
                        empty.style.display = 'block';
                        return;
                    }
                    empty.style.display = 'none';
                    content.style.display = 'block';
                    document.getElementById('meu-progresso-total').textContent = read.length;
                    var days = read.map(function(r) { return r.day_of_year; }).sort(function(a,b) { return a - b; });
                    var last10 = days.slice(-10).reverse();
                    document.getElementById('meu-progresso-dias').textContent = 'Dias lidos (últimos): ' + (last10.length ? last10.join(', ') : '—');
                } catch (e) {
                    loading.style.display = 'none';
                    empty.style.display = 'block';
                    empty.textContent = 'Não foi possível carregar o progresso.';
                }
            }

            (function initContinuarThemeFavoritos() {
                var keyLast = 'bible_last_' + (slug || 'default');
                var keyTheme = 'bible_theme_' + (slug || 'default');
                var keyFav = 'bible_fav_' + (slug || 'default');
                try {
                    var last = localStorage.getItem(keyLast);
                    if (last) {
                        var data = JSON.parse(last);
                        if (data && data.bookId && data.chapter) {
                            var block = document.getElementById('continuar-onde-parei');
                            var link = document.getElementById('link-continuar');
                            var label = document.getElementById('continuar-label');
                            if (block && link && label) {
                                block.style.display = 'block';
                                link.href = '/' + slug + '/bible/' + data.bookId + '/' + data.chapter;
                                label.textContent = (data.bookName || data.bookId) + ' — Cap. ' + data.chapter;
                            }
                        }
                    }
                    var theme = localStorage.getItem(keyTheme) || 'dark';
                    if (theme === 'light') {
                        document.body.classList.add('theme-light');
                        var icon = document.getElementById('icon-theme-public');
                        if (icon) icon.className = 'fas fa-sun';
                    }
                } catch (e) {}
                document.getElementById('btn-theme-public').addEventListener('click', function() {
                    var isLight = document.body.classList.toggle('theme-light');
                    var icon = document.getElementById('icon-theme-public');
                    if (icon) icon.className = isLight ? 'fas fa-sun' : 'fas fa-moon';
                    try { localStorage.setItem(keyTheme, isLight ? 'light' : 'dark'); } catch (e) {}
                });
                try {
                    var favRaw = localStorage.getItem(keyFav);
                    var favList = favRaw ? JSON.parse(favRaw) : [];
                    if (Array.isArray(favList) && favList.length > 0) {
                        var card = document.getElementById('card-favoritos');
                        var listEl = document.getElementById('favoritos-list');
                        if (card && listEl) {
                            card.style.display = 'block';
                            listEl.innerHTML = favList.map(function(f) {
                                var label = (f.bookName || f.bookId) + ' — Cap. ' + f.chapter;
                                return '<a href="/' + slug + '/bible/' + f.bookId + '/' + f.chapter + '" class="bible-ref" style="display:block;margin-bottom:8px">' + label + '</a>';
                            }).join('');
                        }
                    }
                } catch (e) {}
            })();

            function getDayOfYear() {
                const now = new Date();
                const start = new Date(now.getFullYear(), 0, 0);
                const diff = now - start;
                const oneDay = 86400000;
                return Math.min(365, Math.max(1, Math.floor(diff / oneDay)));
            }

            function formatDate(str) {
                if (!str) return '';
                if (/^\d{4}-\d{2}-\d{2}$/.test(str)) {
                    const parts = str.split('-').map(Number);
                    const d = new Date(parts[0], parts[1] - 1, parts[2]);
                    return d.toLocaleDateString('pt-BR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
                }
                const d = new Date(str);
                return d.toLocaleDateString('pt-BR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
            }

            async function loadVerse(dateStr) {
                const url = `${API_URL}/api/bible/verse-of-day?date=${encodeURIComponent(dateStr || '')}&translation=${encodeURIComponent(translation)}`;
                const res = await fetch(url);
                const json = await res.json().catch(() => ({}));
                if (!res.ok || !json.success) throw new Error(json.message || 'Erro ao carregar');
                return json.data;
            }

            let currentVerse = null;

            function renderVerse(verse) {
                currentVerse = verse;
                const content = document.getElementById('bible-content');
                const actions = document.getElementById('bible-actions');
                const dateLabel = document.getElementById('date-label');

                document.getElementById('bible-loading').style.display = 'none';
                dateLabel.textContent = formatDate(verse.date);

                content.innerHTML = `
                    <div class="bible-ref">${verse.ref || ''}</div>
                    <div class="bible-text">"${verse.texto || ''}"</div>
                    ${verse.reflexao ? `
                    <div class="bible-reflexao">
                        <strong>Reflexão</strong>
                        ${verse.reflexao}
                    </div>
                    ` : ''}
                `;
                actions.style.display = 'flex';
                loadVoicesPublic();
            }
            function loadVoicesPublic() {
                if (!window.ConectaTTS || !window.ConectaTTS.hasSupport()) return;
                window.ConectaTTS.loadVoices(['sel-voice-public']);
            }
            loadVoicesPublic();
            if (window.speechSynthesis) {
                window.speechSynthesis.addEventListener('voiceschanged', loadVoicesPublic);
                setTimeout(loadVoicesPublic, 500);
                setTimeout(loadVoicesPublic, 2000);
            }

            function getTextFromElement(el) {
                if (!el) return '';
                return (el.innerText || el.textContent || '').replace(/\s+/g, ' ').trim();
            }
            function speakText(text, voiceSelId) {
                if (!text || !window.speechSynthesis) return;
                speechSynthesis.cancel();
                var voiceSel = voiceSelId ? document.getElementById(voiceSelId) : null;
                if (window.ConectaTTS && window.ConectaTTS.hasSupport()) {
                    window.ConectaTTS.speak(text, { voiceSel: voiceSel, useChunks: true });
                } else {
                    var u = new SpeechSynthesisUtterance(text);
                    u.lang = 'pt-BR';
                    u.rate = 0.9;
                    speechSynthesis.speak(u);
                }
            }
            function bindOuvirParar(containerId, btnOuvirId, btnPararId, voiceSelId) {
                var btnOuvir = document.getElementById(btnOuvirId);
                var btnParar = document.getElementById(btnPararId);
                if (!btnOuvir) return;
                btnOuvir.addEventListener('click', function() {
                    var el = document.getElementById(containerId);
                    var text = getTextFromElement(el);
                    if (!text) return;
                    speakText(text, voiceSelId);
                    if (btnParar) { btnParar.style.display = 'inline-flex'; btnOuvir.style.display = 'none'; }
                    if (window.speechSynthesis) {
                        speechSynthesis.onend = function() {
                            if (btnParar) btnParar.style.display = 'none';
                            if (btnOuvir) btnOuvir.style.display = 'inline-flex';
                        };
                    }
                });
                if (btnParar) {
                    btnParar.addEventListener('click', function() {
                        speechSynthesis.cancel();
                        btnParar.style.display = 'none';
                        if (btnOuvir) btnOuvir.style.display = 'inline-flex';
                    });
                }
            }

            document.getElementById('btn-ouvir').addEventListener('click', function() {
                if (!currentVerse || !currentVerse.texto) return;
                if (window.ConectaTTS && window.ConectaTTS.hasSupport()) {
                    window.ConectaTTS.speak(currentVerse.texto, { voiceSel: document.getElementById('sel-voice-public'), useChunks: false });
                } else {
                    var u = new SpeechSynthesisUtterance(currentVerse.texto);
                    u.lang = 'pt-BR';
                    u.rate = 0.9;
                    speechSynthesis.speak(u);
                }
            });

            bindOuvirParar('devocional-container', 'devocional-btn-ouvir', 'devocional-btn-parar', 'sel-voice-public');
            bindOuvirParar('devocional-biblia-inteira-container', 'dev-biblia-btn-ouvir', 'dev-biblia-btn-parar', 'sel-voice-public');
            bindOuvirParar('dev365-content', 'dev365-btn-ouvir', 'dev365-btn-parar', 'sel-voice-public');
            bindOuvirParar('palavra-container', 'palavra-btn-ouvir', null, 'sel-voice-public');
            bindOuvirParar('salmo-container', 'salmo-btn-ouvir', null, 'sel-voice-public');
            bindOuvirParar('plano-content', 'plano-btn-ouvir', null, 'sel-voice-public');

            document.getElementById('btn-compartilhar').addEventListener('click', function() {
                if (!currentVerse || !currentVerse.texto) return;
                const txt = '"' + currentVerse.texto + '" — ' + (currentVerse.ref || '') + '\n\n— Bíblia King';
                const urlWhatsApp = 'https://wa.me/?text=' + encodeURIComponent(txt);
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(txt).then(function() {
                        if (confirm('Versículo copiado! Deseja compartilhar no WhatsApp?')) window.open(urlWhatsApp);
                    }).catch(function() { window.open(urlWhatsApp); });
                } else {
                    window.open(urlWhatsApp);
                }
            });

            function showError(msg, containerId) {
                const container = document.getElementById(containerId || 'bible-content');
                if (!container) return;
                container.innerHTML = `<div class="bible-error"><i class="fas fa-exclamation-circle"></i><p>${msg}</p></div>`;
            }

