            var DEV_BIBLIA_STORAGE_KEY = 'devocional_biblia_inteira_start_' + (slug || 'default');
            var TOTAL_CHAPTERS = 1189;

            function getDevBibliaStartDate() {
                try {
                    var raw = localStorage.getItem(DEV_BIBLIA_STORAGE_KEY);
                    return raw ? new Date(raw) : null;
                } catch (e) { return null; }
            }
            function setDevBibliaStartDate(date) {
                try { localStorage.setItem(DEV_BIBLIA_STORAGE_KEY, (date || new Date()).toISOString().slice(0, 10)); } catch (e) {}
            }
            function clearDevBibliaStartDate() {
                try { localStorage.removeItem(DEV_BIBLIA_STORAGE_KEY); } catch (e) {}
            }
            function computeSequenceDayNumber() {
                var start = getDevBibliaStartDate();
                if (!start) return null;
                var today = new Date();
                today.setHours(0, 0, 0, 0);
                start.setHours(0, 0, 0, 0);
                var diffMs = today - start;
                var diffDays = Math.floor(diffMs / 86400000);
                if (diffDays < 0) return 1;
                var dayNum = diffDays + 1;
                return ((dayNum - 1) % TOTAL_CHAPTERS) + 1;
            }

            function renderDevocionalBiblia(d) {
                var container = document.getElementById('devocional-biblia-inteira-container');
                if (!container || !d) return;
                var linkCap = '/' + slug + '/bible/' + d.bookId + '/' + d.chapter;
                var html = '<div class="bible-ref" style="font-size:1rem;margin-bottom:12px">' + (d.titulo || d.ref) + '</div>';
                html += '<p style="margin-bottom:12px"><a href="' + linkCap + '" class="bible-ref" style="display:inline-block">' + d.ref + ' — Ler capítulo na Bíblia</a></p>';
                if (d.verse_ref && d.verse_text) {
                    html += '<div style="color:#FFC700;font-size:0.9rem;margin-bottom:8px">' + (d.verse_ref || '') + '</div>';
                    html += '<div class="bible-text" style="color:#e8e8e8;line-height:1.65;margin-bottom:12px;font-style:italic">"' + (d.verse_text || '').replace(/</g, '&lt;') + '"</div>';
                }
                if (d.resumo_capitulo) html += '<div style="color:#A1A1A1;font-size:0.95rem;margin-bottom:12px">' + (d.resumo_capitulo || '').replace(/\n/g, '<br>') + '</div>';
                html += '<div class="bible-text" style="color:#e8e8e8;line-height:1.75;white-space:pre-wrap;margin-bottom:16px">' + (d.reflexao || '').replace(/\n/g, '<br>') + '</div>';
                if (d.aplicacao) html += '<div style="color:#A1A1A1;font-size:0.95rem;margin-bottom:12px"><strong>Aplicação:</strong> ' + (d.aplicacao || '').replace(/\n/g, '<br>') + '</div>';
                if (d.oracao) html += '<div style="color:#FFC700;font-style:italic;font-size:0.95rem">' + (d.oracao || '').replace(/\n/g, '<br>') + '</div>';
                container.innerHTML = html;
            }

            async function loadDevocionalBibliaInteira(useSequence) {
                var container = document.getElementById('devocional-biblia-inteira-container');
                if (!container) return;
                container.innerHTML = '<div class="bible-loading"><i class="fas fa-spinner fa-spin"></i><p>Carregando...</p></div>';
                var url;
                if (useSequence) {
                    var dayNum = computeSequenceDayNumber();
                    if (dayNum == null) dayNum = 1;
                    url = API_URL + '/api/bible/devocional-biblia-inteira?mode=sequence&day=' + dayNum;
                } else {
                    var mes = document.getElementById('dev-biblia-mes').value;
                    var dia = document.getElementById('dev-biblia-dia').value || new Date().getDate();
                    url = API_URL + '/api/bible/devocional-biblia-inteira?month=' + encodeURIComponent(mes) + '&day=' + encodeURIComponent(dia);
                }
                try {
                    var res = await fetch(url);
                    var json = await res.json().catch(function() { return {}; });
                    var d = json.data;
                    if (!d) throw new Error('Devocional não encontrado.');
                    devocionalBibliaInteiraLoaded = true;
                    currentDevBibliaData = d;
                    if (d.mode === 'sequence' && d.dayNumber != null) {
                        var infoEl = document.getElementById('dev-biblia-sequence-info');
