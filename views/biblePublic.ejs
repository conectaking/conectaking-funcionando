            function getVisitorId() {
                var key = 'bible_visitor_id';
                var id = typeof localStorage !== 'undefined' && localStorage.getItem(key);
                if (!id) {
                    id = 'v_' + Date.now() + '_' + Math.random().toString(36).slice(2, 11);
                    try { localStorage.setItem(key, id); } catch (e) {}
                }
                return id;
