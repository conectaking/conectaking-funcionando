<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Estudo: <%= bookName %> — ConectaKing</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', sans-serif;
            background: #0D0D0F;
            background-image: linear-gradient(180deg, #0D0D0F 0%, #12121a 40%, #1a1a1e 70%, #0f0f12 100%);
            color: #ECECEC;
            min-height: 100vh;
            padding: 20px;
            padding-bottom: 40px;
        }
        .study-wrap { max-width: 640px; margin: 0 auto; }
        .back-link { display: inline-flex; align-items: center; gap: 8px; color: #A1A1A1; text-decoration: none; font-size: 0.9rem; margin-bottom: 24px; transition: color 0.2s; }
        .back-link:hover { color: #FFC700; }
        .study-header { text-align: center; margin-bottom: 28px; }
        .study-header .book-icon { font-size: 2.2rem; color: rgba(255,199,0,0.7); margin-bottom: 10px; }
        .study-header h1 { font-family: 'Lora', serif; font-size: 1.5rem; color: #FFC700; line-height: 1.3; }
        .study-card {
            background: rgba(28, 28, 33, 0.95);
            border: 1px solid rgba(255, 199, 0, 0.2);
            border-radius: 16px;
            padding: 28px 24px;
            margin-bottom: 24px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.3);
        }
        .study-card h2 { font-size: 1.1rem; color: #FFC700; margin-bottom: 16px; font-weight: 600; }
        .study-content {
            font-family: 'Lora', serif;
            font-size: 1.05rem;
            line-height: 1.75;
            color: #e8e8e8;
            white-space: pre-wrap;
        }
        .study-content p { margin-bottom: 1em; }
        .chapters-section { margin-top: 28px; }
        .chapters-section h3 { font-size: 1rem; color: #A1A1A1; margin-bottom: 12px; font-weight: 600; }
        .chapters-grid { display: flex; flex-wrap: wrap; gap: 8px 14px; }
        .chapters-grid a {
            display: inline-block;
            padding: 8px 14px;
            border-radius: 8px;
            background: rgba(255,199,0,0.12);
            color: #7dd3fc;
            text-decoration: none;
            font-size: 0.9rem;
            border: 1px solid rgba(255,199,0,0.25);
        }
        .chapters-grid a:hover { background: rgba(255,199,0,0.25); color: #FFC700; }
        .study-empty {
            text-align: center;
            padding: 48px 24px;
            color: #A1A1A1;
        }
        .study-empty .book-icon { font-size: 3rem; color: rgba(255,199,0,0.3); margin-bottom: 16px; }
    </style>
</head>
<body>
    <div class="study-wrap">
        <a href="<%= typeof returnTo !== 'undefined' && returnTo ? returnTo : (typeof biblePanelUrl !== 'undefined' && biblePanelUrl ? biblePanelUrl : (typeof baseUrl !== 'undefined' && baseUrl ? baseUrl : '') + '/dashboard.html') %>" class="back-link"><i class="fas fa-arrow-left"></i> Voltar à Bíblia</a>

        <% if (study && (study.title || study.content)) { %>
        <div class="study-header">
            <div class="book-icon"><i class="fas fa-book-open"></i></div>
            <h1>Estudo: <%= bookName %></h1>
        </div>
        <div class="study-card">
            <% if (study.title) { %><h2><%= study.title %></h2><% } %>
            <div class="study-content"><%= (study.content || '').replace(/\n/g, '<br>') %></div>
            <% if (study.chapters && study.chapters.length > 0) { %>
            <div class="chapters-section">
                <h3><i class="fas fa-list-ol"></i> Estudos por capítulo</h3>
                <div class="chapters-grid">
                    <% study.chapters.forEach(function(c) { %>
                    <a href="/<%= slug %>/bible/<%= bookId %>/<%= c.chapter_number %>"><%= c.title ? 'Cap. ' + c.chapter_number + ' — ' + c.title : 'Cap. ' + c.chapter_number %></a>
                    <% }); %>
                </div>
            </div>
            <% } %>
        </div>
        <% } else { %>
        <div class="study-empty">
            <div class="book-icon"><i class="fas fa-book-open"></i></div>
            <p style="font-size:1.1rem;margin-bottom:12px">Estudo de <strong><%= bookName %></strong> em breve.</p>
            <p style="font-size:0.95rem;margin-bottom:20px">Enquanto isso, leia o livro na Bíblia.</p>
            <a href="/<%= slug %>/bible/<%= bookId %>/1" class="back-link" style="color:#FFC700"><i class="fas fa-book"></i> Ler <%= bookName %> — Capítulo 1</a>
        </div>
        <% } %>
    </div>
</body>
</html>
