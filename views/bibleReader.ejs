<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title><%= chapterData.bookName %> <%= chapterData.chapter %> — ConectaKing</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;600;700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', sans-serif;
            background: #0D0D0F;
            background-image: linear-gradient(180deg, #0D0D0F 0%, #151518 40%, #1a1a1e 70%, #0D0D0F 100%);
            color: #ECECEC;
            min-height: 100vh;
            padding: 20px;
        }
        .reader-wrap { max-width: 560px; margin: 0 auto; }
        .back-link { display: inline-flex; align-items: center; gap: 8px; color: #A1A1A1; text-decoration: none; font-size: 0.9rem; margin-bottom: 20px; transition: color 0.2s; }
        .back-link:hover { color: #FFC700; }
        .reader-header { text-align: center; margin-bottom: 24px; }
        .reader-header .book-icon { font-size: 1.8rem; color: rgba(255,199,0,0.6); margin-bottom: 8px; }
        .reader-header h1 { font-family: 'Lora', serif; font-size: 1.4rem; color: #FFC700; }
        .reader-header .nav-chapters { display: flex; align-items: center; justify-content: center; gap: 12px; margin-top: 12px; }
        .reader-header .nav-chapters a, .reader-header .nav-chapters span {
            padding: 8px 14px; border-radius: 8px; background: rgba(255,199,0,0.15); color: #FFC700;
            text-decoration: none; font-size: 0.9rem;
        }
        .reader-header .nav-chapters a:hover { background: rgba(255,199,0,0.25); }
        .reader-header .nav-chapters span.disabled { opacity: 0.4; cursor: not-allowed; }
        .verse-block { margin-bottom: 14px; padding-left: 8px; border-left: 2px solid rgba(255,199,0,0.3); }
        .verse-block.selectable { cursor: pointer; border-radius: 8px; padding: 8px 8px 8px 12px; transition: background 0.2s; }
        .verse-block.selectable:hover { background: rgba(255,199,0,0.06); }
        .verse-block.selectable.selected { background: rgba(255,199,0,0.15); border-left-color: #FFC700; }
        .verse-num { font-weight: 600; color: #FFC700; font-size: 0.85rem; margin-right: 8px; }
        .verse-text { font-family: 'Lora', serif; font-size: 1.1rem; line-height: 1.7; }
        body.theme-light { background: #f5f5f0; background-image: none; color: #1a1a1a; }
        body.theme-light .back-link { color: #555; }
        body.theme-light .back-link:hover { color: #b8860b; }
        body.theme-light .reader-header h1, body.theme-light .verse-num { color: #b8860b; }
        body.theme-light .verse-text { color: #222; }
        body.theme-light .verse-block.selectable.selected { background: rgba(184,134,11,0.2); border-left-color: #b8860b; }
        body.theme-light .verses-card { background: #fff; border-color: rgba(184,134,11,0.25); box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
        body.theme-light .reader-header .nav-chapters a { background: rgba(184,134,11,0.15); color: #8b6914; }
        body.theme-light .reader-header .nav-chapters a:hover { background: rgba(184,134,11,0.25); }
        body.theme-light .translation-select, body.theme-light .btn-ouvir.secondary { background: rgba(0,0,0,0.06); color: #333; border-color: rgba(184,134,11,0.4); }
        body.theme-light #estudo-cap-content { background: rgba(0,0,0,0.06); border-color: rgba(184,134,11,0.2); }
        .font-small .verse-text { font-size: 0.95rem; }
        .font-normal .verse-text { font-size: 1.1rem; }
        .font-large .verse-text { font-size: 1.3rem; line-height: 1.75; }
        .reader-toolbar { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 12px; margin-top: 16px; margin-bottom: 20px; }
        .translation-select { padding: 8px 12px; border-radius: 8px; background: rgba(255,255,255,0.08); color: #ECECEC; border: 1px solid rgba(255,199,0,0.3); font-size: 0.9rem; cursor: pointer; }
        .translation-select:focus { outline: none; border-color: #FFC700; }
        .translation-select option { color: #000; background: #fff; }
        .btn-ouvir { padding: 10px 20px; background: #FFC700; color: #000; border: none; border-radius: 10px; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; font-size: 0.9rem; }
        .btn-ouvir:hover { filter: brightness(1.1); }
        .btn-download-voice { border: 1px solid rgba(255,199,0,0.5); border-radius: 8px; }
        .btn-download-voice:hover { background: rgba(255,199,0,0.15); }
        .btn-ouvir.secondary { background: rgba(255,255,255,0.08); color: #ECECEC; border: 1px solid rgba(255,199,0,0.4); }
        .btn-ouvir.secondary:hover { background: rgba(255,199,0,0.15); }
        #btn-mark-read.read { background: rgba(34,197,94,0.25); border-color: rgba(34,197,94,0.5); color: #22c55e; }
        .verses-card {
            background: rgba(28, 28, 33, 0.6);
            border: 1px solid rgba(255, 199, 0, 0.15);
            border-radius: 16px;
            padding: 24px 20px;
            margin-top: 8px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.25);
        }
    </style>
</head>
<body>
    <% if (typeof biblePanelUrl === 'undefined' || !biblePanelUrl) { biblePanelUrl = (baseUrl ? String(baseUrl).replace(/\/$/, '') : '') + '/' + slug + '/bible/gn/1'; } %>
    <div class="reader-wrap">
        <a href="javascript:void(0)" id="back-bible-link" class="back-link"><i class="fas fa-arrow-left"></i> Voltar ao painel da Bíblia</a>
        <div class="reader-header">
            <div class="book-icon"><i class="fas fa-book-open"></i></div>
            <h1><%= chapterData.bookName %> — Capítulo <%= chapterData.chapter %></h1>
            <div class="nav-chapters">
                <% if (chapterData.chapter > 1) { %>
                <a href="/<%= slug %>/bible/<%= chapterData.bookId %>/<%= chapterData.chapter - 1 %><%= tParam %>"><i class="fas fa-chevron-left"></i> Cap. <%= chapterData.chapter - 1 %></a>
                <% } else { %>
                <span class="disabled"><i class="fas fa-chevron-left"></i> Anterior</span>
                <% } %>
                <span>Cap. <%= chapterData.chapter %> de <%= chapterData.totalChapters %></span>
                <% if (chapterData.chapter < chapterData.totalChapters) { %>
                <a href="/<%= slug %>/bible/<%= chapterData.bookId %>/<%= chapterData.chapter + 1 %><%= tParam %>">Cap. <%= chapterData.chapter + 1 %> <i class="fas fa-chevron-right"></i></a>
                <% } else { %>
                <span class="disabled">Próximo <i class="fas fa-chevron-right"></i></span>
                <% } %>
            </div>
            <div class="reader-toolbar" style="flex-wrap:wrap;gap:10px;align-items:center;">
                <label for="sel-translation" style="color:#A1A1A1;font-size:0.85rem;">Tradução:</label>
                <select id="sel-translation" class="translation-select" onchange="var t=this.value; if(t) location.href='/<%= slug %>/bible/<%= chapterData.bookId %>/<%= chapterData.chapter %>'+(t!=='nvi'?'?translation='+encodeURIComponent(t):'');">
                    <option value="nvi"<%= (typeof translation !== 'undefined' && translation === 'nvi') ? ' selected' : '' %>>NVI (Nova Versão Internacional)</option>
                    <option value="arc"<%= (typeof translation !== 'undefined' && translation === 'arc') ? ' selected' : '' %>>ARC (Almeida Revista e Corrigida)</option>
                    <option value="acf"<%= (typeof translation !== 'undefined' && translation === 'acf') ? ' selected' : '' %>>ACF (Almeida Corrigida Fiel)</option>
                    <option value="ntlh"<%= (typeof translation !== 'undefined' && translation === 'ntlh') ? ' selected' : '' %>>NTLH (Nova Tradução na Linguagem de Hoje)</option>
                    <option value="ara"<%= (typeof translation !== 'undefined' && translation === 'ara') ? ' selected' : '' %>>ARA (Almeida Revisada e Atualizada)</option>
                    <option value="kja"<%= (typeof translation !== 'undefined' && translation === 'kja') ? ' selected' : '' %>>KJA (King James Atualizada)</option>
                    <option value="kjv"<%= (typeof translation !== 'undefined' && translation === 'kjv') ? ' selected' : '' %>>KJV (King James Version)</option>
                </select>
                <label for="sel-voice" style="color:#A1A1A1;font-size:0.85rem;">Voz:</label>
                <select id="sel-voice" class="translation-select" style="color:#ECECEC;background:rgba(255,255,255,0.08);border:1px solid rgba(255,199,0,0.3);cursor:pointer"><option value="">Padrão</option></select>
                <span id="tts-aviso" style="font-size:0.8rem;color:#FFA500;display:none">Instale vozes pt-BR (Brasil) nas Configurações do dispositivo</span>
                <a href="https://play.google.com/store/apps/details?id=com.google.android.tts" id="btn-baixar-vozes" target="_blank" rel="noopener" class="btn-download-voice" style="display:none;font-size:0.8rem;color:#FFC700;text-decoration:none;padding:6px 10px;white-space:nowrap"><i class="fas fa-download"></i> Baixar vozes pt-BR</a>
                <button type="button" class="btn-ouvir" id="btn-ouvir"><i class="fas fa-volume-up"></i> Ouvir capítulo</button>
                <button type="button" class="btn-ouvir" id="btn-parar" style="background:rgba(239,68,68,0.8);"><i class="fas fa-stop"></i> Parar</button>
                <button type="button" class="btn-ouvir secondary" id="btn-mark-read" style="background:rgba(255,255,255,0.08);color:#ECECEC;border:1px solid rgba(255,199,0,0.4);" title="Marcar este capítulo como lido"><i class="far fa-check-circle"></i> Marcar como lido</button>
                <a href="javascript:void(0)" id="btn-estudo-cap" class="btn-ouvir secondary" style="text-decoration:none;display:inline-flex;align-items:center;gap:6px" title="Ver estudo deste capítulo"><i class="fas fa-book-open"></i> Ver estudo</a>
                <a href="/<%= slug %>/bible" target="_blank" rel="noopener" class="btn-ouvir secondary" style="text-decoration:none;display:inline-flex;align-items:center;gap:6px" title="Ver estudo completo deste livro (66 livros) no perfil público"><i class="fas fa-book"></i> Estudo completo do livro</a>
                <span style="color:#A1A1A1;font-size:0.85rem;margin-left:4px">Fonte:</span>
                <button type="button" class="btn-ouvir secondary btn-font" data-size="small" title="Fonte menor" style="padding:8px 12px;font-weight:600">A-</button>
                <button type="button" class="btn-ouvir secondary btn-font active" data-size="normal" title="Fonte normal" style="padding:8px 12px;font-weight:600">A</button>
                <button type="button" class="btn-ouvir secondary btn-font" data-size="large" title="Fonte maior" style="padding:8px 12px;font-weight:600">A+</button>
                <button type="button" class="btn-ouvir secondary" id="btn-theme" title="Alternar tema claro/escuro" style="padding:8px 12px"><i class="fas fa-moon" id="icon-theme"></i></button>
                <button type="button" class="btn-ouvir secondary" id="btn-favorito" title="Adicionar aos favoritos" style="padding:8px 12px"><i class="far fa-star"></i> Favorito</button>
                <button type="button" class="btn-ouvir" id="btn-share-selection" style="display:none;padding:8px 14px"><i class="fas fa-share-alt"></i> Compartilhar seleção</button>
            </div>
            <div id="estudo-cap-content" style="display:none;margin-top:16px;padding:16px;background:rgba(0,0,0,0.25);border:1px solid rgba(255,199,0,0.2);border-radius:12px;">
                <div id="estudo-cap-body"></div>
            </div>
        </div>
        <div class="verses-card">
        <div id="verses-container">
            <% chapterData.verses.forEach(function(v) { %>
            <div class="verse-block selectable" data-verse="<%= v.verse %>">
                <span class="verse-num"><%= v.verse %></span>
                <span class="verse-text"><%= v.text %></span>
            </div>
            <% }); %>
        </div>
        </div>
    </div>
    <script src="/js/tts.js"></script>
    <script>
        (function() {
            const verses = document.querySelectorAll('.verse-block');
            const texts = Array.from(verses).map(v => v.querySelector('.verse-text').textContent);
            const fullText = texts.join(' ');
            const biblePanelUrl = <%- JSON.stringify(biblePanelUrl) %>;
            const readerSlug = <%- JSON.stringify(slug) %>;
            const readerBookId = <%- JSON.stringify(chapterData.bookId) %>;
            const readerChapter = <%- JSON.stringify(chapterData.chapter) %>;
            const readerBookName = <%- JSON.stringify(chapterData.bookName || '') %>;
            const readerTranslation = <%- JSON.stringify(typeof translation !== 'undefined' ? translation : 'nvi') %>;
            var translationNames = { nvi: 'NVI (Nova Versão Internacional)', arc: 'ARC (Almeida Revista e Corrigida)', acf: 'ACF (Almeida Corrigida Fiel)', ntlh: 'NTLH (Nova Tradução na Linguagem de Hoje)', ara: 'ARA (Almeida Revisada e Atualizada)', kja: 'KJA (King James Atualizada)', kjv: 'KJV (King James Version)' };
            var btnOuvir = document.getElementById('btn-ouvir');
            var btnShareSel = document.getElementById('btn-share-selection');

            function getBibleReadKey() { return 'bible_read_' + (readerSlug || 'default'); }
            function getBibleReadList() {
                try {
                    var raw = localStorage.getItem(getBibleReadKey());
                    return raw ? JSON.parse(raw) : [];
                } catch (e) { return []; }
            }
            function setBibleReadList(arr) {
                try { localStorage.setItem(getBibleReadKey(), JSON.stringify(arr)); } catch (e) {}
            }
            function chapterKey(bookId, ch) { return (bookId || '') + '_' + (ch || ''); }
            function isChapterRead(bookId, ch) { return getBibleReadList().indexOf(chapterKey(bookId, ch)) !== -1; }
            function setChapterRead(bookId, ch) {
                var list = getBibleReadList();
                var key = chapterKey(bookId, ch);
                if (list.indexOf(key) === -1) { list.push(key); setBibleReadList(list); }
            }
            function updateMarkReadButton() {
                var btn = document.getElementById('btn-mark-read');
                if (!btn) return;
                if (isChapterRead(readerBookId, readerChapter)) {
                    btn.innerHTML = '<i class="fas fa-check-circle"></i> Lido';
                    btn.classList.add('read');
                    btn.disabled = true;
                } else {
                    btn.innerHTML = '<i class="far fa-check-circle"></i> Marcar como lido';
                    btn.classList.remove('read');
                    btn.disabled = false;
                }
            }
            updateMarkReadButton();
            document.getElementById('btn-mark-read').addEventListener('click', function() {
                if (this.disabled) return;
                setChapterRead(readerBookId, readerChapter);
                updateMarkReadButton();
            });

            (function() {
                var keyFont = 'bible_font_size_' + (readerSlug || 'default');
                var keyTheme = 'bible_theme_' + (readerSlug || 'default');
                var keyLast = 'bible_last_' + (readerSlug || 'default');
                try {
                    var savedFont = localStorage.getItem(keyFont) || 'normal';
                    document.body.classList.add('font-' + savedFont);
                    document.querySelectorAll('.btn-font').forEach(function(b) {
                        b.classList.toggle('active', b.getAttribute('data-size') === savedFont);
                    });
                    var savedTheme = localStorage.getItem(keyTheme) || 'dark';
                    if (savedTheme === 'light') {
                        document.body.classList.add('theme-light');
                        var icon = document.getElementById('icon-theme');
                        if (icon) { icon.className = 'fas fa-sun'; }
                    }
                } catch (e) {}
                document.querySelectorAll('.btn-font').forEach(function(btn) {
                    btn.addEventListener('click', function() {
                        var size = this.getAttribute('data-size');
                        document.body.classList.remove('font-small', 'font-normal', 'font-large');
                        document.body.classList.add('font-' + size);
                        document.querySelectorAll('.btn-font').forEach(function(b) { b.classList.remove('active'); });
                        this.classList.add('active');
                        try { localStorage.setItem(keyFont, size); } catch (e) {}
                    });
                });
                document.getElementById('btn-theme').addEventListener('click', function() {
                    var isLight = document.body.classList.toggle('theme-light');
                    var icon = document.getElementById('icon-theme');
                    if (icon) { icon.className = isLight ? 'fas fa-sun' : 'fas fa-moon'; }
                    try { localStorage.setItem(keyTheme, isLight ? 'light' : 'dark'); } catch (e) {}
                });
                try {
                    localStorage.setItem(keyLast, JSON.stringify({
                        bookId: readerBookId,
                        chapter: readerChapter,
                        bookName: readerBookName
                    }));
                } catch (e) {}
            })();

            (function() {
                var keyFav = 'bible_fav_' + (readerSlug || 'default');
                function getFavList() {
                    try {
                        var raw = localStorage.getItem(keyFav);
                        return raw ? JSON.parse(raw) : [];
                    } catch (e) { return []; }
                }
                function setFavList(arr) {
                    try { localStorage.setItem(keyFav, JSON.stringify(arr)); } catch (e) {}
                }
                function isFav(bookId, ch) {
                    return getFavList().some(function(f) { return f.bookId === bookId && f.chapter === ch; });
                }
                function updateFavButton() {
                    var btn = document.getElementById('btn-favorito');
                    if (!btn) return;
                    var fav = isFav(readerBookId, readerChapter);
                    btn.innerHTML = fav ? '<i class="fas fa-star"></i> Nos favoritos' : '<i class="far fa-star"></i> Favorito';
                    btn.title = fav ? 'Remover dos favoritos' : 'Adicionar aos favoritos';
                }
                updateFavButton();
                document.getElementById('btn-favorito').addEventListener('click', function() {
                    var list = getFavList();
                    var idx = list.findIndex(function(f) { return f.bookId === readerBookId && f.chapter === readerChapter; });
                    if (idx >= 0) {
                        list.splice(idx, 1);
                        setFavList(list);
                    } else {
                        list.push({ bookId: readerBookId, chapter: readerChapter, bookName: readerBookName });
                        setFavList(list);
                    }
                    updateFavButton();
                });
            })();

            (function() {
                var apiUrl = (typeof window !== 'undefined' && window.location && window.location.origin) ? window.location.origin : '';
                var btnEstudo = document.getElementById('btn-estudo-cap');
                var boxEstudo = document.getElementById('estudo-cap-content');
                var bodyEstudo = document.getElementById('estudo-cap-body');
                if (!btnEstudo || !boxEstudo || !bodyEstudo) return;
                btnEstudo.addEventListener('click', function() {
                    if (boxEstudo.style.display === 'block' && bodyEstudo.innerHTML) {
                        boxEstudo.style.display = 'none';
                        return;
                    }
                    if (bodyEstudo.getAttribute('data-loaded') === '1') {
                        boxEstudo.style.display = boxEstudo.style.display === 'none' ? 'block' : 'none';
                        return;
                    }
                    bodyEstudo.innerHTML = '<span style="color:#A1A1A1"><i class="fas fa-spinner fa-spin"></i> Carregando...</span>';
                    boxEstudo.style.display = 'block';
                    fetch(apiUrl + '/api/bible/study/book/' + encodeURIComponent(readerBookId) + '/chapter/' + readerChapter)
                        .then(function(r) { return r.json().then(function(j) { return { ok: r.ok, json: j }; }); })
                        .then(function(result) {
                            bodyEstudo.setAttribute('data-loaded', '1');
                            if (!result.ok || !result.json.success) {
                                bodyEstudo.innerHTML = '<p style="color:#A1A1A1;font-size:0.9rem">Nenhum estudo disponível para este capítulo.</p>';
                                return;
                            }
                            var d = result.json.data;
                            var html = (d.title ? '<h3 style="color:#FFC700;font-size:1rem;margin-bottom:10px">' + d.title + '</h3>' : '') +
                                '<div style="color:#e8e8e8;line-height:1.65;white-space:pre-wrap;font-size:0.95rem">' + (d.content || '').replace(/\n/g, '<br>') + '</div>';
                            bodyEstudo.innerHTML = html;
                        })
                        .catch(function() {
                            bodyEstudo.setAttribute('data-loaded', '1');
                            bodyEstudo.innerHTML = '<p style="color:#A1A1A1;font-size:0.9rem">Erro ao carregar o estudo.</p>';
                        });
                });
            })();

            document.getElementById('back-bible-link').addEventListener('click', function() {
                window.location.href = biblePanelUrl;
            });

            (function verseSelection() {
                var blocks = document.querySelectorAll('.verse-block.selectable');
                function updateShareButton() {
                    var n = document.querySelectorAll('.verse-block.selectable.selected').length;
                    if (btnShareSel) btnShareSel.style.display = n > 0 ? 'inline-flex' : 'none';
                }
                blocks.forEach(function(block) {
                    block.addEventListener('click', function() {
                        this.classList.toggle('selected');
                        updateShareButton();
                    });
                });
                btnShareSel && btnShareSel.addEventListener('click', function() {
                    var selected = Array.from(document.querySelectorAll('.verse-block.selectable.selected'))
                        .map(function(b) {
                            var num = parseInt(b.getAttribute('data-verse'), 10);
                            var text = (b.querySelector('.verse-text') || {}).textContent || '';
                            return { verse: num, text: text };
                        })
                        .sort(function(a, b) { return a.verse - b.verse; });
                    if (selected.length === 0) return;
                    var nums = selected.map(function(s) { return s.verse; });
                    var refPart = readerBookName + ' ' + readerChapter + ':';
                    if (nums.length === 1) refPart += nums[0];
                    else if (nums.length === 2) refPart += nums[0] + ', ' + nums[1];
                    else {
                        var ranges = [], i = 0;
                        while (i < nums.length) {
                            var start = nums[i], end = start;
                            while (i + 1 < nums.length && nums[i + 1] === end + 1) { i++; end = nums[i]; }
                            ranges.push(start === end ? String(start) : start + '-' + end);
                            i++;
                        }
                        refPart += ranges.join(', ');
                    }
                    var transName = translationNames[readerTranslation] || readerTranslation;
                    var lines = [refPart + ' — ' + transName, ''];
                    selected.forEach(function(s) { lines.push(s.verse + ' ' + s.text); });
                    var toShare = lines.join('\n');
                    if (navigator.share && /mobile|android|iphone|ipad/i.test(navigator.userAgent)) {
                        navigator.share({ title: refPart, text: toShare }).catch(function() {
                            copyToClipboard(toShare);
                        });
                    } else {
                        copyToClipboard(toShare);
                    }
                    function copyToClipboard(str) {
                        if (navigator.clipboard && navigator.clipboard.writeText) {
                            navigator.clipboard.writeText(str).then(function() { alert('Copiado para a área de transferência.'); }).catch(function() { fallbackCopy(str); });
                        } else fallbackCopy(str);
                    }
                    function fallbackCopy(str) {
                        var ta = document.createElement('textarea'); ta.value = str; ta.style.position = 'fixed'; ta.style.opacity = '0'; document.body.appendChild(ta); ta.select();
                        try { document.execCommand('copy'); alert('Copiado para a área de transferência.'); } catch (e) { alert('Texto pronto para compartilhar:\n\n' + str); }
                        document.body.removeChild(ta);
                    }
                });
            })();

            function stopSpeech() { speechSynthesis.cancel(); if (btnOuvir) btnOuvir.innerHTML = '<i class="fas fa-volume-up"></i> Ouvir capítulo'; }
            function speak() {
                if (window.ConectaTTS && window.ConectaTTS.hasSupport()) {
                    window.ConectaTTS.speak(fullText, { voiceSel: document.getElementById('sel-voice'), useChunks: true });
                } else {
                    speechSynthesis.cancel();
                    var u = new SpeechSynthesisUtterance(fullText);
                    u.lang = 'pt-BR';
                    u.rate = 0.85;
                    speechSynthesis.speak(u);
                }
            }
            document.querySelectorAll('.nav-chapters a').forEach(function(a) { a.addEventListener('click', stopSpeech); });
            document.getElementById('btn-ouvir').addEventListener('click', function() {
                if (speechSynthesis.speaking) { speechSynthesis.pause(); btnOuvir.innerHTML = '<i class="fas fa-play"></i> Continuar'; }
                else if (speechSynthesis.paused) { speechSynthesis.resume(); btnOuvir.innerHTML = '<i class="fas fa-pause"></i> Pausar'; }
                else { speak(); btnOuvir.innerHTML = '<i class="fas fa-pause"></i> Pausar'; }
            });
            document.getElementById('btn-parar').addEventListener('click', stopSpeech);
            speechSynthesis.onend = function() { if (btnOuvir) btnOuvir.innerHTML = '<i class="fas fa-volume-up"></i> Ouvir capítulo'; };

            var loadVoicesRetries = 0;
            function loadVoices() {
                if (!window.ConectaTTS || !window.ConectaTTS.hasSupport()) return;
                var list = window.ConectaTTS.loadVoices(['sel-voice']);
                if (!list.length && loadVoicesRetries < 15) {
                    loadVoicesRetries++;
                    setTimeout(loadVoices, loadVoicesRetries * 200);
                }
            }
            loadVoices();
            (function() {
                var isAndroid = /Android/i.test(navigator.userAgent);
                var btn = document.getElementById('btn-baixar-vozes');
                if (btn && isAndroid) {
                    btn.style.display = 'inline-flex';
                    btn.style.alignItems = 'center';
                    btn.style.gap = '6px';
                    btn.href = 'intent://#Intent;action=android.settings.TEXT_TO_SPEECH_SETTINGS;package=com.android.settings;S.browser_fallback_url=' + encodeURIComponent('https://play.google.com/store/apps/details?id=com.google.android.tts') + ';end';
                }
            })();
            if (window.speechSynthesis) {
                speechSynthesis.addEventListener('voiceschanged', loadVoices);
                setTimeout(loadVoices, 100);
                setTimeout(loadVoices, 500);
                setTimeout(loadVoices, 1500);
                setTimeout(loadVoices, 3000);
            }
            var selVoice = document.getElementById('sel-voice');
            if (selVoice) {
                selVoice.addEventListener('focus', loadVoices);
                selVoice.addEventListener('click', loadVoices);
            }
            function showAviso() {
                var list = window.ConectaTTS ? window.ConectaTTS.getPreferredVoices(window.speechSynthesis.getVoices()) : [];
                var hasBR = list.length > 0;
                var aviso = document.getElementById('tts-aviso');
                if (aviso) aviso.style.display = hasBR ? 'none' : 'inline';
            }
            setTimeout(showAviso, 3000);
        })();
    </script>
</body>
</html>
