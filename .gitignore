# =============================================================================
# FRONT-END: deploy manual na Hostinger (public_html)
# King Docs: versão canónica em public/; cópia em public_html/ para o domínio servir
# (npm run sync:king-docs). Estes HTML são versionados para não desalinharem.
# Exceção: PHP usado no Hostinger (.htaccess) para OG + HTML da galeria cliente.
# Guia: docs/HOSTINGER-DEPLOY.txt
# =============================================================================
public_html/
!public_html/kingSelectionGallery.php
!public_html/kingDocs.html
!public_html/kingDocsShare.html
!public_html/index.html

# Backend - arquivos na raiz (server.js, routes/, views/, etc.) são commitados
