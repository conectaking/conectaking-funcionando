# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables (caminho do .env: raiz do back-end = .../conectaking-funcionando)
# Opcional: .env.path = uma linha com caminho para o .env (ex.: pasta noutro disco)
.env
.env.path
.env.local
.env.*.local

# Logs
logs
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Build
dist/
build/

# Temporary files
tmp/
temp/
*.tmp

# Uploads (se houver pasta de uploads local)
uploads/
public/uploads/

# Cache
.cache/

# =============================================================================
# FRONT-END: NÃO COMMITAR — deploy manual no hosting
# Caminho do front-end: .../conectaking-funcionando/public_html
# Caminho do back-end (ponto de envio Git): .../conectaking-funcionando
# Nada de public_html sobe para o repositório; front-end sobe manualmente.
# Exceções: ficheiros de deploy/referência e PHP do King Selection no Hostinger.
# (!public_html/ é necessário para o Git aceitar ficheiros negados dentro da pasta)
# =============================================================================
public_html/**
!public_html/
!public_html/kingSelectionGallery.php
!public_html/.htaccess
!public_html/HOSTINGER-DEPLOY.txt

# Backend - arquivos na raiz (server.js, routes/, views/, etc.) são commitados
